PORT=7575
SESSION_SECRET=change_me_generate_with_node_generate-secret.js
NODE_ENV=development

# Timezone for rendered timestamps in the UI.
# TZ is any IANA zone (e.g. Asia/Jakarta, Asia/Makassar, Asia/Jayapura, UTC).
# TZ_LABEL is the short label shown after the time (WIB / WITA / WIT / UTC ...).
TZ=Asia/Jakarta
TZ_LABEL=WIB
