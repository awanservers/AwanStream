PORT=7575
SESSION_SECRET=change_me_generate_with_node_generate-secret.js
NODE_ENV=development

# Timezone for rendered timestamps in the UI.
# TZ is any IANA zone (e.g. Asia/Jakarta, Asia/Makassar, Asia/Jayapura, UTC).
# TZ_LABEL is the short label shown after the time (WIB / WITA / WIT / UTC ...).
TZ=Asia/Jakarta
TZ_LABEL=WIB

# YouTube OAuth credentials (optional — only needed for YouTube upload feature).
# Get these from Google Cloud Console:
#   1. https://console.cloud.google.com/apis/credentials
#   2. Create OAuth client ID → Web application
#   3. Add authorized redirect URI: http://localhost:7575/youtube/callback
#      (replace localhost:7575 with your actual app URL if deployed)
# YOUTUBE_CLIENT_ID=your-id.apps.googleusercontent.com
# YOUTUBE_CLIENT_SECRET=GOCSPX-your-secret
# YOUTUBE_REDIRECT_URI=http://localhost:7575/youtube/callback
