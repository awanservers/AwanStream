<% if (typeof error !== 'undefined' && error) { %>
  <script>
    window.addEventListener('DOMContentLoaded', () => {
      Swal.fire({
        icon: 'error',
        title: 'Gagal',
        text: '<%= error %>',
        confirmButtonColor: '#e5484d',
        background: '#161b2c',
        color: '#f0f3f8'
      });
    });
  </script>
<% } %>
<% if (typeof notice !== 'undefined' && notice) { %>
  <script>
    window.addEventListener('DOMContentLoaded', () => {
      Swal.fire({
        icon: 'success',
        title: 'Berhasil',
        text: '<%= notice %>',
        confirmButtonColor: '#4f8cff',
        background: '#161b2c',
        color: '#f0f3f8',
        timer: 3000,
        timerProgressBar: true
      });
    });
  </script>
<% } %>
