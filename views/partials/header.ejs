<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' · AwanStream' : 'AwanStream' %></title>
  <link rel="stylesheet" href="/css/app.css" />
</head>
<body class="<%= typeof currentUser !== 'undefined' && currentUser ? 'app' : 'auth' %>">
<% if (typeof currentUser !== 'undefined' && currentUser) {
     const activePath = typeof activeNav !== 'undefined' ? activeNav : '';
%>
  <input type="checkbox" id="sidebar-toggle" class="sidebar-toggle-input" />
  <label for="sidebar-toggle" class="sidebar-backdrop" aria-hidden="true"></label>

  <aside class="sidebar">
    <div class="sidebar-brand">
      <span class="brand-dot"></span>
      <span class="brand-name">AwanStream</span>
    </div>
    <nav class="sidebar-nav">
      <a href="/" class="nav-item <%= activePath === 'dashboard' ? 'active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l2-2 7-7 7 7 2 2"/><path d="M5 10v10h14V10"/></svg>
        Dashboard
      </a>
      <a href="/videos" class="nav-item nav-parent <%= activePath === 'videos' || activePath === 'playlists' || activePath === 'audio' ? 'parent-active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6a2 2 0 0 1 2-2h6l2 2h8a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6z"/></svg>
        Library
      </a>
      <a href="/videos" class="nav-item nav-child <%= activePath === 'videos' ? 'active' : '' %>">
        Videos
      </a>
      <a href="/audio" class="nav-item nav-child <%= activePath === 'audio' ? 'active' : '' %>">
        Audio
      </a>
      <a href="/playlists" class="nav-item nav-child <%= activePath === 'playlists' ? 'active' : '' %>">
        Playlists
      </a>
      <a href="/streams" class="nav-item nav-parent <%= activePath === 'streams' || activePath === 'streams-playlist' || activePath === 'schedules' || activePath === 'history' ? 'parent-active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12a7 7 0 0 1 14 0"/><path d="M2 12a10 10 0 0 1 20 0"/><circle cx="12" cy="12" r="2"/></svg>
        Streams
      </a>
      <a href="/streams/single" class="nav-item nav-child <%= activePath === 'streams' ? 'active' : '' %>">
        Single Stream
      </a>
      <a href="/streams/playlist" class="nav-item nav-child <%= activePath === 'streams-playlist' ? 'active' : '' %>">
        Playlist Stream
      </a>
      <a href="/schedules" class="nav-item nav-child <%= activePath === 'schedules' ? 'active' : '' %>">
        Schedules
      </a>
      <a href="/history" class="nav-item nav-child <%= activePath === 'history' ? 'active' : '' %>">
        History
      </a>
      <a href="/looper" class="nav-item <%= activePath === 'looper' ? 'active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
        Loop
      </a>
      <a href="/youtube" class="nav-item <%= activePath === 'youtube' ? 'active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        YouTube
      </a>
    </nav>
    <div class="sidebar-user">
      <div class="avatar"><%= currentUser.username.charAt(0).toUpperCase() %></div>
      <div class="user-meta">
        <div class="user-name">@<%= currentUser.username %></div>
        <form method="POST" action="/logout" class="inline">
          <button type="submit" class="btn-link">Logout</button>
        </form>
      </div>
    </div>
    <div class="sidebar-version" title="Booted at <%= typeof appBootedAt !== 'undefined' ? appBootedAt : '' %>">
      v<%= typeof appVersion !== 'undefined' ? appVersion : 'dev' %>
    </div>
  </aside>

  <div class="main">
    <header class="topbar">
      <label for="sidebar-toggle" class="hamburger" aria-label="Toggle menu">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </label>
      <div class="topbar-title">
        <h1><%= typeof pageTitle !== 'undefined' ? pageTitle : (typeof title !== 'undefined' ? title : 'AwanStream') %></h1>
        <% if (typeof pageSubtitle !== 'undefined' && pageSubtitle) { %>
          <p class="muted small"><%= pageSubtitle %></p>
        <% } %>
      </div>
      <div class="topbar-actions">
        <% if (typeof topbarActions !== 'undefined') { %>
          <%- topbarActions %>
        <% } %>
        <span class="user-pill">@<%= currentUser.username %></span>
      </div>
    </header>
    <main class="content">
<% } else { %>
  <main class="container">
<% } %>
