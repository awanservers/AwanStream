<%- include('partials/header', {
  title: 'Loop',
  activeNav: 'looper',
  pageTitle: 'Loop Video',
  pageSubtitle: 'Perpanjang clip pendek jadi video panjang (1-24 jam) untuk 24/7 livestream.',
}) %>
<%- include('partials/flash', { error, notice }) %>

<% if (videos.length === 0) { %>
  <div class="card empty">
    <p class="muted">Belum ada video dengan durasi terdeteksi.</p>
    <p class="muted small">Upload clip dulu di <a href="/videos">Library</a>. Setelah upload, durasi otomatis di-probe dan video akan muncul di sini.</p>
  </div>
<% } else { %>
  <div class="loop-builder">
    <form method="POST" action="/looper/start" id="loop-form">
      <div class="loop-builder-grid">
        <div class="loop-main">
          <div class="loop-field">
            <label for="source_video_id">Video sumber</label>
            <select name="source_video_id" id="source_video_id" required>
              <option value="">Pilih video...</option>
              <% videos.forEach(v => {
                   const dur = Math.round(v.duration_seconds || 0);
                   const durLabel = dur >= 60 ? Math.floor(dur/60) + 'm ' + (dur%60) + 's' : dur + 's';
                   const sizeLabel = v.size_bytes ? (v.size_bytes / (1024*1024)).toFixed(1) + ' MB' : '';
                   const resLabel = v.src_width && v.src_height ? v.src_width + 'x' + v.src_height : '';
                   const meta = [durLabel, resLabel, sizeLabel].filter(Boolean).join(' - ');
              %>
                <option value="<%= v.id %>"
                        data-duration="<%= v.duration_seconds %>"
                        data-thumb="<%= v.thumbnail ? '/videos/' + v.id + '/thumb' : '' %>"
                        data-title="<%= v.title %>"
                        data-meta="<%= meta %>">
                  <%= v.title %> - <%= meta %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="loop-field">
            <div class="loop-field-head">
              <label>Target durasi</label>
              <span class="small muted">30 menit - 24 jam</span>
            </div>
            <div class="preset-grid">
              <% presets.forEach((p, idx) => { %>
                <label class="preset-chip">
                  <input type="radio" name="target_preset" value="<%= p.key %>"
                         <%= idx === 2 ? 'checked' : '' %>>
                  <span><%= p.label %></span>
                </label>
              <% }) %>
              <label class="preset-chip">
                <input type="radio" name="target_preset" value="custom">
                <span>Custom</span>
              </label>
            </div>
            <div class="loop-inline-row" id="custom-duration-row" style="display:none;">
              <input type="number" name="custom_minutes" id="custom_minutes"
                     min="1" max="1440" step="1" placeholder="Menit">
              <span class="small muted">menit</span>
            </div>
          </div>

          <div class="loop-field">
            <label for="title">Title output <span class="muted small">(opsional)</span></label>
            <input type="text" name="title" id="title"
                   placeholder="Kosongkan untuk auto-generate">
          </div>
        </div>

        <aside class="loop-side">
          <div class="loop-source-preview">
            <img id="loop-source-thumb" alt="" loading="lazy" style="display:none;">
            <div class="loop-source-empty" id="loop-source-empty">Preview video</div>
          </div>
          <div class="loop-source-info">
            <strong id="loop-source-title"></strong>
            <span class="small muted" id="loop-source-meta"></span>
          </div>
          <div id="estimate-row" style="display:none;">
            <div class="alert alert-info" id="estimate-box"></div>
          </div>
        </aside>

        <div class="loop-options-grid">
          <div class="loop-option-panel">
            <label class="loop-toggle">
              <input type="checkbox" name="smooth" id="smooth" checked>
              <span>
                <strong>Smooth mode</strong>
                <span class="small muted">Crossfade di boundary loop supaya transisi lebih halus.</span>
              </span>
            </label>
            <div class="loop-range" id="crossfade-control">
              <div class="loop-range-head">
                <span class="small muted">Crossfade</span>
                <strong><span id="crossfade-value">1.5</span>s</strong>
              </div>
              <input type="range" name="crossfade_seconds" id="crossfade_seconds"
                     min="0.5" max="3.0" step="0.1" value="1.5">
              <div class="loop-range-scale small muted">
                <span>0.5s</span>
                <span>1.5s</span>
                <span>3.0s</span>
              </div>
            </div>
          </div>

          <div class="loop-option-panel">
            <div class="loop-panel-title">Audio overlay <span class="muted small">(opsional)</span></div>
            <div class="loop-audio-grid">
              <label>Audio track
                <select name="audio_id" id="audio_id">
                  <option value="">Tanpa audio overlay</option>
                  <% if (typeof audioTracks !== 'undefined' && audioTracks.length > 0) { %>
                    <% audioTracks.forEach(a => { %>
                      <option value="<%= a.id %>"><%= a.title %><% if (a.duration_seconds) { %> - <%= Math.floor(a.duration_seconds/60) %>m <%= Math.round(a.duration_seconds%60) %>s<% } %></option>
                    <% }) %>
                  <% } else { %>
                    <option value="" disabled>Belum ada audio. Upload di /audio dulu.</option>
                  <% } %>
                </select>
              </label>
              <label>Mode
                <select name="audio_mode" id="audio_mode">
                  <option value="mix" selected>Mix</option>
                  <option value="replace">Replace</option>
                </select>
              </label>
              <label>Volume
                <input type="number" name="audio_volume" value="0.3" min="0" max="1" step="0.1">
              </label>
            </div>
          </div>
        </div>

        <div class="alert alert-error" id="loop-form-error" style="display:none;"></div>
      </div>

      <footer class="loop-builder-footer">
        <a href="/videos" class="btn">Cancel</a>
        <button type="submit" class="btn btn-primary">Start loop</button>
      </footer>
    </form>
  </div>
<% } %>

<h2 style="margin-top:28px; margin-bottom:12px;">Active jobs</h2>
<div id="active-jobs-wrap">
  <% if (activeJobs.length === 0) { %>
    <div class="card empty">
      <p class="muted">Tidak ada loop job yang sedang berjalan.</p>
    </div>
  <% } else { %>
    <div class="table-wrap card card-flush">
      <table class="table" id="jobs-table">
        <thead><tr>
          <th>Job</th>
          <th>Source → Output</th>
          <th>Target</th>
          <th>Phase</th>
          <th>Progress</th>
          <th>Speed</th>
          <th>ETA</th>
          <th>Actions</th>
        </tr></thead>
        <tbody>
          <% activeJobs.forEach(j => { %>
            <tr data-job-id="<%= j.jobId %>">
              <td>#<%= j.jobId %><div class="small muted"><%= j.mode %></div></td>
              <td class="small">
                <%= j.sourceTitle %><br>
                <span class="muted">→ <%= j.outputTitle %></span>
              </td>
              <td class="small">
                <% const t = j.target; %>
                <%= t >= 3600 ? (t/3600).toFixed(t%3600===0?0:1) + 'h' : Math.round(t/60) + 'm' %>
              </td>
              <td class="small job-phase">
                <%= j.progress.phaseLabel || '-' %>
              </td>
              <td>
                <div class="progress">
                  <div class="progress-bar" style="width: <%= j.progress.percent || 0 %>%;"></div>
                </div>
                <span class="small muted job-percent"><%= j.progress.percent || 0 %>%</span>
              </td>
              <td class="small job-speed"><%= j.progress.speed ? j.progress.speed.toFixed(1) + 'x' : '-' %></td>
              <td class="small job-eta">-</td>
              <td>
                <form method="POST" action="/looper/<%= j.jobId %>/cancel" class="inline"
                      data-confirm="Cancel loop job ini? Video output yang belum selesai akan dihapus."
                      data-confirm-title="Cancel loop"
                      data-confirm-action="Cancel job">
                  <button type="submit" class="btn btn-danger">Cancel</button>
                </form>
                <button type="button" class="btn btn-icon" title="View Log"
                        onclick="openLoopLog('<%= j.jobId %>')">📄</button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<% if (typeof recentErrors !== 'undefined' && recentErrors && recentErrors.length > 0) { %>
<h2 style="margin-top:28px; margin-bottom:12px;">Recent errors</h2>
<div class="table-wrap card card-flush">
  <table class="table">
    <thead><tr>
      <th>Video</th>
      <th>Error</th>
      <th>Time</th>
      <th>Log</th>
    </tr></thead>
    <tbody>
      <% recentErrors.forEach(v => { %>
        <tr>
          <td class="small"><%= v.title %></td>
          <td class="small" style="color:var(--danger);"><%= v.last_error || '-' %></td>
          <td class="small muted"><%= formatTime(v.created_at) %></td>
          <td>
            <% if (v.loop_job_id) { %>
              <button type="button" class="btn btn-icon" title="View Log"
                      onclick="openLoopLog('<%= v.loop_job_id %>')">📄</button>
            <% } else { %>
              -
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>

<!-- Loop Log Modal -->
<dialog id="loop-log-modal" class="modal" style="width:min(90vw,800px); max-height:80vh;">
  <header class="modal-header">
    <h3 id="loop-log-title">Loop Job Log</h3>
    <button data-close-modal class="btn-close" aria-label="Close">&times;</button>
  </header>
  <div class="modal-body" style="padding:0;">
    <pre id="loop-log-content" style="background:var(--bg); color:var(--text); padding:16px; margin:0; overflow:auto; max-height:60vh; font-size:12px; line-height:1.5; white-space:pre-wrap; word-break:break-all;"></pre>
  </div>
  <footer class="modal-footer">
    <button type="button" id="loop-log-refresh" class="btn">Refresh</button>
    <button type="button" data-close-modal class="btn btn-primary">Close</button>
  </footer>
</dialog>

<script>
// Loop log modal handler
let currentLogUrl = null;
function openLoopLog(jobId) {
  currentLogUrl = '/looper/' + jobId + '/log';
  document.getElementById('loop-log-title').textContent = 'Loop Job #' + jobId + ' — Log';
  fetchLoopLog();
  document.getElementById('loop-log-modal').showModal();
}
function openLoopLogByVideo(videoId) {
  currentLogUrl = '/looper/video/' + videoId + '/log';
  document.getElementById('loop-log-title').textContent = 'Loop Log (Video #' + videoId + ')';
  fetchLoopLog();
  document.getElementById('loop-log-modal').showModal();
}
async function fetchLoopLog() {
  const el = document.getElementById('loop-log-content');
  try {
    const r = await fetch(currentLogUrl, { cache: 'no-store' });
    el.textContent = r.ok ? await r.text() : 'Log not found.';
    el.scrollTop = el.scrollHeight;
  } catch (e) {
    el.textContent = 'Error fetching log: ' + e.message;
  }
}
document.getElementById('loop-log-refresh').addEventListener('click', fetchLoopLog);
document.getElementById('loop-log-modal').addEventListener('click', function(e) {
  if (e.target === this) this.close();
});
document.querySelectorAll('#loop-log-modal [data-close-modal]').forEach(btn => {
  btn.addEventListener('click', () => document.getElementById('loop-log-modal').close());
});
</script>

<script>
(function() {
  const presetRadios = document.querySelectorAll('input[name="target_preset"]');
  const customRow = document.getElementById('custom-duration-row');
  const customInput = document.getElementById('custom_minutes');
  const sourceSelect = document.getElementById('source_video_id');
  const estimateRow = document.getElementById('estimate-row');
  const estimateBox = document.getElementById('estimate-box');
  const sourceThumb = document.getElementById('loop-source-thumb');
  const sourceEmpty = document.getElementById('loop-source-empty');
  const sourceTitle = document.getElementById('loop-source-title');
  const sourceMeta = document.getElementById('loop-source-meta');
  const formError = document.getElementById('loop-form-error');

  function selectedTargetSeconds() {
    const checked = document.querySelector('input[name="target_preset"]:checked');
    if (!checked) return null;
    if (checked.value === 'custom') {
      const m = Number(customInput.value);
      if (!Number.isFinite(m) || m <= 0) return null;
      return Math.round(m * 60);
    }
    const map = { '30m': 1800, '1h': 3600, '2h': 7200, '3h': 10800, '6h': 21600, '12h': 43200, '24h': 86400 };
    return map[checked.value] || null;
  }

  function updateCustomVisibility() {
    if (!customRow) return;
    const customChecked = document.querySelector('input[name="target_preset"][value="custom"]');
    customRow.style.display = (customChecked && customChecked.checked) ? 'flex' : 'none';
  }

  function updateEstimate() {
    if (!estimateRow || !sourceSelect) return;
    const target = selectedTargetSeconds();
    const opt = sourceSelect.selectedOptions[0];
    const srcDur = opt ? Number(opt.dataset.duration) : null;
    if (!target || !srcDur) {
      estimateRow.style.display = 'none';
      return;
    }
    const loops = Math.ceil(target / srcDur);
    const outputH = (target / 3600).toFixed(target % 3600 === 0 ? 0 : 1);
    const srcLabel = srcDur >= 60
      ? Math.floor(srcDur / 60) + 'm ' + Math.round(srcDur % 60) + 's'
      : Math.round(srcDur) + 's';
    const mode = document.getElementById('smooth') && document.getElementById('smooth').checked
      ? 'Smooth mode aktif: buat seamless unit dulu, lalu loop sampai target.'
      : 'Fast mode: langsung loop copy, cocok kalau source sudah seamless.';
    estimateBox.textContent =
      'Source ' + srcLabel + ' akan di-loop sekitar ' + loops + 'x untuk output ' +
      outputH + ' jam. ' + mode;
    estimateRow.style.display = 'block';
  }

  function updateSourcePreview() {
    if (!sourceSelect) return;
    const opt = sourceSelect.selectedOptions[0];
    const hasVideo = opt && opt.value;
    const thumb = hasVideo ? opt.dataset.thumb : '';
    if (sourceTitle) sourceTitle.textContent = hasVideo ? (opt.dataset.title || opt.textContent.trim()) : '';
    if (sourceMeta) sourceMeta.textContent = hasVideo ? (opt.dataset.meta || '') : '';
    if (sourceThumb && sourceEmpty) {
      if (thumb) {
        sourceThumb.src = thumb;
        sourceThumb.style.display = 'block';
        sourceEmpty.style.display = 'none';
      } else {
        sourceThumb.removeAttribute('src');
        sourceThumb.style.display = 'none';
        sourceEmpty.style.display = 'flex';
      }
    }
    clearLoopError();
    updateEstimate();
  }

  function showLoopError(message) {
    if (!formError) return;
    formError.textContent = message;
    formError.style.display = 'block';
  }

  function clearLoopError() {
    if (!formError) return;
    formError.textContent = '';
    formError.style.display = 'none';
  }

  presetRadios.forEach(r => r.addEventListener('change', () => {
    clearLoopError();
    updateCustomVisibility();
    updateEstimate();
  }));
  if (customInput) customInput.addEventListener('input', () => {
    clearLoopError();
    updateEstimate();
  });
  if (sourceSelect) sourceSelect.addEventListener('change', updateSourcePreview);

  // Crossfade slider — live update label and toggle visibility with smooth mode.
  const crossfadeSlider = document.getElementById('crossfade_seconds');
  const crossfadeValue = document.getElementById('crossfade-value');
  const crossfadeControl = document.getElementById('crossfade-control');
  const smoothCheck = document.getElementById('smooth');

  if (crossfadeSlider && crossfadeValue) {
    crossfadeSlider.addEventListener('input', () => {
      crossfadeValue.textContent = parseFloat(crossfadeSlider.value).toFixed(1);
    });
  }
  if (smoothCheck && crossfadeControl) {
    const updateCrossfadeVisibility = () => {
      crossfadeControl.style.opacity = smoothCheck.checked ? '1' : '0.4';
      if (crossfadeSlider) crossfadeSlider.disabled = !smoothCheck.checked;
      updateEstimate();
    };
    smoothCheck.addEventListener('change', updateCrossfadeVisibility);
    updateCrossfadeVisibility();
  }

  const form = document.getElementById('loop-form');
  if (form) {
    form.addEventListener('submit', (e) => {
      if (!sourceSelect.value) {
        e.preventDefault();
        showLoopError('Pilih video sumber dulu.');
        sourceSelect.focus();
        return;
      }
      const target = selectedTargetSeconds();
      if (!target) {
        e.preventDefault();
        showLoopError('Pilih target durasi.');
        if (customInput) customInput.focus();
        return;
      }
      const opt = sourceSelect.selectedOptions[0];
      const srcDur = opt ? Number(opt.dataset.duration) : null;
      if (srcDur && target < srcDur) {
        e.preventDefault();
        showLoopError('Target lebih pendek dari video sumber. Pilih durasi yang lebih panjang.');
      }
    });
  }

  // Live poll active jobs every 2s.
  function formatEta(sec) {
    if (!sec || sec < 0) return '-';
    if (sec < 60) return sec + 's';
    if (sec < 3600) return Math.floor(sec / 60) + 'm ' + (sec % 60) + 's';
    const h = Math.floor(sec / 3600);
    const m = Math.floor((sec % 3600) / 60);
    return h + 'h ' + m + 'm';
  }

  let lastJobIds = <%- JSON.stringify(activeJobs.map(j => j.jobId)) %>;

  async function poll() {
    try {
      const r = await fetch('/looper/progress', { cache: 'no-store' });
      if (!r.ok) return;
      const data = await r.json();
      const currentIds = data.jobs.map(j => j.jobId);
      const disappeared = lastJobIds.some(id => !currentIds.includes(id));
      if (disappeared) { window.location.reload(); return; }
      const newAppeared = currentIds.some(id => !lastJobIds.includes(id));
      if (newAppeared) { window.location.reload(); return; }
      data.jobs.forEach(j => {
        const row = document.querySelector('tr[data-job-id="' + j.jobId + '"]');
        if (!row) return;
        const bar = row.querySelector('.progress-bar');
        if (bar) bar.style.width = (j.percent || 0) + '%';
        const pct = row.querySelector('.job-percent');
        if (pct) pct.textContent = (j.percent || 0) + '%';
        const sp = row.querySelector('.job-speed');
        if (sp) sp.textContent = j.speed ? j.speed.toFixed(1) + 'x' : '-';
        const eta = row.querySelector('.job-eta');
        if (eta) eta.textContent = formatEta(j.etaSec);
        const ph = row.querySelector('.job-phase');
        if (ph) ph.textContent = j.phaseLabel || '-';
      });
    } catch (_) {}
  }
  if (lastJobIds.length > 0) setInterval(poll, 2000);

  // Init.
  updateCustomVisibility();
  updateSourcePreview();
})();
</script>

<%- include('partials/footer') %>
