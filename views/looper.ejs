<%- include('partials/header', {
  title: 'Loop',
  activeNav: 'looper',
  pageTitle: 'Loop Video',
  pageSubtitle: 'Perpanjang clip pendek jadi video panjang untuk 24/7 livestream.',
  topbarActions: `
    <button type="button" class="btn btn-primary" data-open-modal="create-loop">+ Create new loop</button>
  `,
}) %>
<%- include('partials/flash', { error, notice }) %>

<style>
/* Custom Looper styles */
#create-loop .tab-panel {
  padding: 1.5rem 1.25rem;
  min-height: 380px;
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
.spin {
  animation: spin 2s linear infinite;
}
.loop-field-row {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}
.loop-slider-control {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  margin-top: 0.5rem;
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.25rem;
}
.loop-slider-control .slider-row {
  display: flex;
  align-items: center;
  gap: 1rem;
}
.loop-slider-control input[type="range"] {
  flex: 1;
  padding: 0;
  height: 6px;
  background: var(--border);
  border: none;
  border-radius: 3px;
  outline: none;
  cursor: pointer;
}
.loop-slider-control label {
  display: flex;
  justify-content: space-between;
  font-weight: 500;
  color: var(--text);
  font-size: 0.9rem;
}
.loop-slider-control .slider-max {
  font-size: 0.85rem;
  color: var(--muted);
}
</style>

<% if (loopedVideos.length === 0) { %>
  <div class="card empty">
    <p class="muted">Belum ada video hasil loop.</p>
    <button type="button" class="btn btn-primary" data-open-modal="create-loop">+ Buat loop pertama</button>
  </div>
<% } else { %>
  <div class="table-wrap card card-flush">
    <table class="table videos-table">
      <thead><tr>
        <th class="col-w-thumb"></th>
        <th class="col-w-title">Title</th>
        <th class="col-w-status">Status</th>
        <th class="col-w-actions">Actions</th>
      </tr></thead>
      <tbody>
        <% loopedVideos.forEach(v => { %>
          <tr>
            <td class="col-thumb">
              <% if (v.thumbnail) { %>
                <button type="button" class="video-thumb-btn"
                        data-open-modal="video-preview"
                        data-video-id="<%= v.id %>"
                        data-video-src="/videos/<%= v.id %>/file"
                        data-video-title="<%= v.title %>"
                        data-video-info="<%= v.src_width && v.src_height ? v.src_width + '×' + v.src_height : '' %><%= v.size_bytes ? ' · ' + (v.size_bytes / (1024*1024)).toFixed(1) + ' MB' : '' %><%= v.duration_seconds ? ' · ' + Math.floor(v.duration_seconds/60) + 'm ' + Math.floor(v.duration_seconds%60) + 's' : '' %>"
                        title="Preview video">
                  <img src="/videos/<%= v.id %>/thumb" alt="" class="video-thumb" loading="lazy">
                  <span class="video-thumb-play">▶</span>
                </button>
              <% } else { %>
                <form method="POST" action="/videos/<%= v.id %>/regen-thumb" class="inline" title="Generate thumbnail">
                  <button type="submit" class="video-thumb video-thumb-empty">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="14" height="14" rx="2"/><path d="M22 7l-6 5 6 5V7z"/></svg>
                  </button>
                </form>
              <% } %>
            </td>
            <td class="video-title-cell">
              <div class="video-title" title="<%= v.title %>"><%= v.title %></div>
              <div class="video-meta small muted">
                <%= (v.size_bytes / (1024*1024)).toFixed(1) %> MB
                · <%= formatTime(v.created_at) %>
                <% if (v.duration_seconds) { %>
                  <% const dur = Math.round(v.duration_seconds); %>
                  <% const h = Math.floor(dur / 3600); %>
                  <% const m = Math.floor((dur % 3600) / 60); %>
                  <% const s = dur % 60; %>
                  · <%= h > 0 ? h + 'h ' + m + 'm' : m + 'm ' + s + 's' %>
                <% } %>
                <% if (v.src_width && v.src_height) { %>
                  · <%= v.src_width %>×<%= v.src_height %>
                <% } %>
              </div>
            </td>
            <td>
              <% if (v.status === 'ready') { %>
                <span class="badge badge-running">ready</span>
              <% } else if (v.status === 'transcoding') { %>
                <span class="badge badge-idle">looping…</span>
              <% } else if (v.status === 'error') { %>
                <span class="badge badge-error" title="<%= v.last_error || 'Error' %>">error</span>
              <% } else { %>
                <span class="badge badge-idle"><%= v.status %></span>
              <% } %>
            </td>
            <td class="actions">
              <button type="button" class="btn-icon"
                      data-open-modal="edit-video"
                      data-video-id="<%= v.id %>"
                      data-video-title="<%= v.title %>"
                      data-folder-id="<%= v.folder_id || '' %>"
                      title="Edit">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </button>
              <a href="/videos/<%= v.id %>/download" class="btn-icon" title="Download" download>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              </a>
              <button type="button" class="btn-icon"
                      data-open-modal="video-detail"
                      data-video-id="<%= v.id %>"
                      data-video-title="<%= v.title %>"
                      title="Detail Video">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
              </button>
              <% if (v.loop_job_id) { %>
                <button type="button" class="btn-icon" 
                        style="color: <%= v.status === 'error' ? 'var(--danger)' : (v.status === 'transcoding' ? 'var(--primary)' : 'var(--muted)') %>;"
                        onclick="openLoopLog('<%= v.loop_job_id %>')"
                        title="Lihat Log Proses">
                  <% if (v.status === 'transcoding') { %>
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="spin">
                      <polyline points="23 4 23 10 17 10"></polyline>
                      <polyline points="1 20 1 14 7 14"></polyline>
                      <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
                    </svg>
                  <% } else { %>
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                      <polyline points="14 2 14 8 20 8"></polyline>
                      <line x1="16" y1="13" x2="8" y2="13"></line>
                      <line x1="16" y1="17" x2="8" y2="17"></line>
                      <polyline points="10 9 9 9 8 9"></polyline>
                    </svg>
                  <% } %>
                </button>
              <% } %>
              <% if (v.status === 'ready') { %>
                <% if (v.youtube_status === 'uploading' || v.youtube_status === 'pending') { %>
                  <button type="button" class="btn-icon"
                          title="Uploading to YouTube — <%= v.youtube_percent || 0 %>% — klik untuk lihat detail"
                          data-yt-watch-job="<%= v.youtube_job_id %>"
                          data-yt-watch-video="<%= v.id %>"
                          data-yt-resume-job="<%= v.youtube_job_id %>"
                          data-video-title="<%= v.title %>"
                          style="color:var(--accent);">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    <span class="yt-pct" style="font-size:10px;font-weight:600;margin-left:2px;"><%= v.youtube_percent || 0 %>%</span>
                  </button>
                <% } else if (v.youtube_video_id) { %>
                  <a href="https://studio.youtube.com/video/<%= v.youtube_video_id %>/edit"
                     target="_blank" rel="noopener"
                     class="btn-icon" style="color:#22c55e;"
                     title="Uploaded — open in YouTube Studio">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                  </a>
                <% } else if (v.youtube_interrupted && youtubeConnected) { %>
                  <button type="button" class="btn-icon"
                          data-open-modal="upload-youtube"
                          data-video-id="<%= v.id %>"
                          data-video-title="<%= v.title %>"
                          title="Upload was interrupted by server restart — click to retry from start"
                          style="color:#f59e0b;">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                  </button>
                <% } else if (youtubeConnected) { %>
                  <button type="button" class="btn-icon"
                          data-open-modal="upload-youtube"
                          data-video-id="<%= v.id %>"
                          data-video-title="<%= v.title %>"
                          title="Upload to YouTube">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                  </button>
                <% } %>
              <% } %>
              <form method="POST" action="/videos/<%= v.id %>/delete" class="inline"
                    data-confirm="Hapus video hasil loop '<%= v.title %>'? File di disk akan ikut terhapus."
                    data-confirm-title="Hapus video"
                    data-confirm-action="Hapus">
                <input type="hidden" name="back" value="/looper<%= typeof page !== 'undefined' && page > 1 ? '?page=' + page : '' %>">
                <button class="btn-icon btn-icon-danger" type="submit" title="Delete">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                </button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% if (typeof totalPages !== 'undefined' && totalPages > 1) {
       const baseUrl = '/looper?';
       const pageUrl = (n) => baseUrl + 'page=' + n;
       const windowSize = 2;
       const pages = [];
       for (let i = 1; i <= totalPages; i++) {
         if (i === 1 || i === totalPages || (i >= page - windowSize && i <= page + windowSize)) {
           pages.push(i);
         } else if (pages[pages.length - 1] !== '...') {
           pages.push('...');
         }
       }
  %>
    <div class="pagination">
      <span class="small muted">Showing <%= (page - 1) * perPage + 1 %>–<%= Math.min(page * perPage, totalCount) %> of <%= totalCount %></span>
      <div class="pagination-buttons">
        <% if (page > 1) { %>
          <a href="<%= pageUrl(page - 1) %>" class="btn btn-sm">← Prev</a>
        <% } else { %>
          <span class="btn btn-sm btn-disabled">← Prev</span>
        <% } %>
        <% pages.forEach(p => { %>
          <% if (p === '...') { %>
            <span class="page-ellipsis">…</span>
          <% } else if (p === page) { %>
            <span class="btn btn-sm btn-primary btn-disabled"><%= p %></span>
          <% } else { %>
            <a href="<%= pageUrl(p) %>" class="btn btn-sm"><%= p %></a>
          <% } %>
        <% }); %>
        <% if (page < totalPages) { %>
          <a href="<%= pageUrl(page + 1) %>" class="btn btn-sm">Next →</a>
        <% } else { %>
          <span class="btn btn-sm btn-disabled">Next →</span>
        <% } %>
      </div>
    </div>
  <% } %>
<% } %>



<!-- Create Loop Form Modal -->
<dialog id="create-loop" class="modal modal-xl">
  <div class="modal-card">
    <header class="modal-header">
      <h2>Create New Loop</h2>
      <button type="button" class="modal-close" data-close-modal aria-label="Close">×</button>
    </header>
    <% if (videos.length === 0) { %>
      <div class="modal-body">
        <div class="card empty" style="margin:0;">
          <p class="muted">Belum ada video dengan status ready di library.</p>
          <p class="muted small">Silakan jalankan <strong>Prepare</strong> terlebih dahulu di <a href="/videos">Library</a> agar video bisa diloop.</p>
        </div>
      </div>
      <footer class="modal-footer">
        <button type="button" class="btn" data-close-modal>Tutup</button>
      </footer>
    <% } else { %>
      <form method="POST" action="/looper/start" id="loop-form">
        <!-- Tabs Header -->
        <div class="modal-tabs">
          <button type="button" class="tab active" data-tab="loop-tab-video">Video</button>
          <button type="button" class="tab" data-tab="loop-tab-transition">Transition</button>
          <button type="button" class="tab" data-tab="loop-tab-audio">Audio</button>
        </div>

        <div class="modal-body" style="padding-top: 0.5rem;">
          <!-- Tab 1: Video -->
          <div id="loop-tab-video" class="tab-panel active">
            <div class="loop-builder-grid" style="padding: 0.5rem 0 1.25rem;">
              <div class="loop-main">
                <div class="loop-field">
                  <label for="source_video_id">Video sumber</label>
                  <select name="source_video_id" id="source_video_id" required>
                    <option value="">Pilih video...</option>
                    <% videos.forEach(v => {
                         const dur = Math.round(v.duration_seconds || 0);
                         const durLabel = dur >= 60 ? Math.floor(dur/60) + 'm ' + (dur%60) + 's' : dur + 's';
                         const sizeLabel = v.size_bytes ? (v.size_bytes / (1024*1024)).toFixed(1) + ' MB' : '';
                         const resLabel = v.src_width && v.src_height ? v.src_width + 'x' + v.src_height : '';
                         const meta = [durLabel, resLabel, sizeLabel].filter(Boolean).join(' - ');
                    %>
                      <option value="<%= v.id %>"
                              data-duration="<%= v.duration_seconds %>"
                              data-thumb="<%= v.thumbnail ? '/videos/' + v.id + '/thumb' : '' %>"
                              data-title="<%= v.title %>"
                              data-meta="<%= meta %>">
                        <%= v.title %> - <%= meta %>
                      </option>
                    <% }) %>
                  </select>
                </div>

                <!-- Loop Options (Preset Duration) -->
                <div class="loop-option-panel">
                  <div class="loop-panel-title">Target durasi</div>
                  <div class="loop-preset-chips">
                    <!-- First option: Custom -->
                    <label class="preset-chip">
                      <input type="radio" name="target_preset" value="custom" checked>
                      <span>Custom</span>
                    </label>
                    <% presets.forEach(p => { %>
                      <label class="preset-chip">
                        <input type="radio" name="target_preset" value="<%= p.key %>" data-seconds="<%= p.seconds %>">
                        <span><%= p.label %></span>
                      </label>
                    <% }) %>
                  </div>

                  <!-- Custom minutes input (active by default now since custom is first) -->
                  <div id="custom-duration-row" class="custom-duration-box" style="margin-top: 12px;">
                    <label for="custom_minutes">Durasi custom (menit)</label>
                    <input type="number" name="custom_minutes" id="custom_minutes" min="1" step="1" value="30">
                  </div>
                </div>

                <!-- Output video title (optional) -->
                <div class="loop-field" style="margin-top: 16px;">
                  <label for="loop_title">Title video hasil loop <span class="muted small">(opsional)</span></label>
                  <input type="text" name="title" id="loop_title" placeholder="Pakai nama default jika kosong">
                </div>
              </div>

              <div class="loop-sidebar" style="max-width: 320px; width: 100%; justify-self: center; align-self: center;">
                <div class="loop-source-preview">
                  <img id="loop-source-thumb" src="" alt="Source video thumbnail preview" style="display:none;">
                  <div id="loop-source-empty" class="loop-source-empty" style="flex-direction: column; gap: 8px;">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="2" y1="7" x2="7" y2="7"/><line x1="2" y1="17" x2="7" y2="17"/><line x1="17" y1="17" x2="22" y2="17"/><line x1="17" y1="7" x2="22" y2="7"/></svg>
                    <span style="font-size: 0.85rem;">Preview Thumbnail</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Tab 2: Transition (Advanced settings) -->
          <div id="loop-tab-transition" class="tab-panel">
            <div class="loop-field-row">
              <div class="loop-panel-title">Pengaturan transisi</div>
              
              <label class="inline-check" style="display: flex; cursor: pointer; margin-top: 0.5rem;">
                <input type="checkbox" name="smooth" id="smooth" checked value="1">
                <span>Smooth mode (seamless crossfade transisi)</span>
              </label>

              <div id="crossfade-control" class="loop-slider-control">
                <label for="crossfade_seconds">
                  <span>Durasi crossfade</span>
                  <span style="color: var(--primary); font-weight: 600;"><span id="crossfade-value">1.5</span> detik</span>
                </label>
                <div class="slider-row">
                  <span style="font-size: 0.85rem; color: var(--muted);">0.3s</span>
                  <input type="range" name="crossfade_seconds" id="crossfade_seconds" min="0.3" max="3.0" step="0.1" value="1.5">
                  <span class="slider-max">3.0s</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Tab 3: Audio (Audio overlay) -->
          <div id="loop-tab-audio" class="tab-panel">
            <div class="loop-field-row">
              <div class="loop-panel-title">Audio overlay (opsional)</div>
              
              <div class="loop-audio-grid" style="margin-top: 0.5rem;">
                <label>
                  <span>Audio track</span>
                  <select name="audio_id" id="audio_id">
                    <option value="">Tanpa audio overlay</option>
                    <% if (typeof audioTracks !== 'undefined' && audioTracks.length > 0) { %>
                      <% audioTracks.forEach(a => { %>
                        <option value="<%= a.id %>"><%= a.title %><% if (a.duration_seconds) { %> - <%= Math.floor(a.duration_seconds/60) %>m <%= Math.round(a.duration_seconds%60) %>s<% } %></option>
                      <% }) %>
                    <% } else { %>
                      <option value="" disabled>Belum ada audio. Upload di /audio dulu.</option>
                    <% } %>
                  </select>
                </label>
                <label>
                  <span>Mode</span>
                  <select name="audio_mode" id="audio_mode">
                    <option value="mix" selected>Mix</option>
                    <option value="replace">Replace</option>
                  </select>
                </label>
                <label>
                  <span>Volume</span>
                  <input type="number" name="audio_volume" value="0.3" min="0" max="1" step="0.1">
                </label>
              </div>
            </div>
          </div>

          <div class="alert alert-error" id="loop-form-error" style="display:none; margin-top: 16px;"></div>
        </div>
        <footer class="modal-footer">
          <button type="button" class="btn" data-close-modal>Batal</button>
          <button type="submit" class="btn btn-primary">Start loop</button>
        </footer>
      </form>
    <% } %>
  </div>
</dialog>

<!-- Loop Job Detail Modal (Monitoring & Log) -->
<dialog id="loop-job-detail" class="modal modal-lg">
  <div class="modal-card">
    <header class="modal-header">
      <h2 id="loop-job-title">Loop Job Detail</h2>
      <button type="button" class="modal-close" data-close-modal aria-label="Close">×</button>
    </header>
    <div class="modal-body">
      <div class="job-status" style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
        <span class="badge" id="loop-job-badge" style="text-transform: uppercase;">loading</span>
        <span class="small muted" id="loop-job-eta-top"></span>
      </div>
      <div class="progress progress-lg" style="margin-bottom: 1rem;">
        <div class="progress-bar" id="loop-job-bar" style="width:0%"></div>
        <div class="progress-label" id="loop-job-label">starting…</div>
      </div>
      <div class="job-stats" id="loop-job-stats" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; background: rgba(255, 255, 255, 0.02); padding: 1rem; border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 1.25rem;">
        <div style="display: flex; flex-direction: column;"><span class="muted small" style="text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">Elapsed</span> <strong id="loop-job-time">-</strong></div>
