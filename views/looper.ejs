<script>
// Loop job detail modal handler
(function() {
  const dlg = document.getElementById('loop-job-detail');
  if (!dlg) return;

  const titleEl = document.getElementById('loop-job-title');
  const badgeEl = document.getElementById('loop-job-badge');
  const etaTopEl = document.getElementById('loop-job-eta-top');
  const barEl = document.getElementById('loop-job-bar');
  const labelEl = document.getElementById('loop-job-label');
  const timeEl = document.getElementById('loop-job-time');
  const speedEl = document.getElementById('loop-job-speed');
  const phaseEl = document.getElementById('loop-job-phase');
  const etaEl = document.getElementById('loop-job-eta');
  const logEl = document.getElementById('loop-job-log');
  const cancelForm = document.getElementById('loop-job-cancel-form');

  let currentJobId = null;
  let pollInterval = null;
  let stickToBottom = true;

  function fmtSec(s) {
    if (s == null || !Number.isFinite(s) || s < 0) return '-';
    const h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60), sec = Math.floor(s % 60);
    return (h ? String(h).padStart(2, '0') + ':' : '') +
      String(m).padStart(2, '0') + ':' + String(sec).padStart(2, '0');
  }

  window.openLoopLog = function(jobId) {
    currentJobId = jobId;
    titleEl.textContent = 'Loop Job #' + jobId;
    
    // Set cancel form target
    cancelForm.action = '/looper/' + jobId + '/cancel';
    
    // Reset modal UI
    badgeEl.className = 'badge badge-idle';
    badgeEl.textContent = 'LOADING';
    etaTopEl.textContent = '';
    barEl.style.width = '0%';
    labelEl.textContent = 'loading…';
    timeEl.textContent = '-';
    speedEl.textContent = '-';
    phaseEl.textContent = '-';
    etaEl.textContent = '-';
    logEl.textContent = 'Loading log…';
    cancelForm.style.display = 'none';

    // Show modal
    dlg.showModal();
    
    // Start polling immediately
    pollJob();
    pollInterval = setInterval(pollJob, 1500);
  };

  // Support opening logs by video id as well
  window.openLoopLogByVideo = function(videoId) {
    currentJobId = null;
    titleEl.textContent = 'Loop Log (Video #' + videoId + ')';
    badgeEl.className = 'badge badge-running';
    badgeEl.textContent = 'COMPLETED';
    etaTopEl.textContent = '';
    barEl.style.width = '100%';
    labelEl.textContent = '100% · Done';
    timeEl.textContent = '-';
    speedEl.textContent = '-';
    phaseEl.textContent = 'completed';
    etaEl.textContent = '-';
    cancelForm.style.display = 'none';
    logEl.textContent = 'Loading log…';

    dlg.showModal();
    fetchLogOnly('/looper/video/' + videoId + '/log');
  };

  async function fetchLogOnly(url) {
    try {
      const r = await fetch(url, { cache: 'no-store' });
      logEl.textContent = r.ok ? await r.text() : 'Log not found.';
      logEl.scrollTop = logEl.scrollHeight;
    } catch (err) {
      logEl.textContent = 'Error loading log: ' + err.message;
    }
  }

  async function pollJob() {
    if (!currentJobId) return;

    try {
      // 1. Fetch active jobs progress
      const r = await fetch('/looper/progress', { cache: 'no-store' });
      if (!r.ok) throw new Error('Progress failed');
      const data = await r.json();
      
      const job = data.jobs.find(j => String(j.jobId) === String(currentJobId));
      
      if (job) {
        // Job is still active
        badgeEl.className = 'badge badge-idle';
        badgeEl.textContent = job.phase || 'running';
        
        const pct = job.percent || 0;
        barEl.style.width = pct + '%';
        
        const parts = [];
        parts.push(pct + '%');
        if (job.elapsedSec) parts.push(fmtSec(job.elapsedSec));
        if (job.speed) parts.push(job.speed.toFixed(2) + 'x');
        labelEl.textContent = parts.join(' · ') || 'working…';

        timeEl.textContent = fmtSec(job.elapsedSec);
        speedEl.textContent = job.speed ? job.speed.toFixed(2) + 'x' : '-';
        phaseEl.textContent = job.phaseLabel || '-';
        etaEl.textContent = job.etaSec ? fmtSec(job.etaSec) : '-';
        etaTopEl.textContent = job.etaSec ? '~' + fmtSec(job.etaSec) + ' left' : '';
        
        cancelForm.style.display = '';
      } else {
        // Job is no longer active (finished or failed)
        badgeEl.className = 'badge badge-running';
        badgeEl.textContent = 'FINISHED';
        barEl.style.width = '100%';
        labelEl.textContent = '100% · Done';
        phaseEl.textContent = 'completed';
        cancelForm.style.display = 'none';
        
        // Stop polling since it's done
        clearInterval(pollInterval);
        pollInterval = null;
      }
      
      // 2. Fetch tail logs
      const logR = await fetch('/looper/' + currentJobId + '/log', { cache: 'no-store' });
      if (logR.ok) {
        const txt = await logR.text();
        if (txt !== logEl.textContent) {
          logEl.textContent = txt || '(belum ada log)';
          if (stickToBottom) logEl.scrollTop = logEl.scrollHeight;
        }
      }
    } catch (err) {
      console.error('Error polling job:', err);
    }
  }

  dlg.addEventListener('close', () => {
    if (pollInterval) {
      clearInterval(pollInterval);
      pollInterval = null;
    }
    currentJobId = null;
  });

  // Handle Cancel Form submission via AJAX
  cancelForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!currentJobId) return;
    if (!confirm('Cancel loop job ini? Video output yang belum selesai akan dihapus.')) return;
    
    try {
      const r = await fetch(cancelForm.action, {
        method: 'POST',
        headers: { 'Accept': 'application/json' }
      });
      if (r.ok) {
        dlg.close();
        window.location.reload();
      } else {
        const j = await r.json();
        alert('Gagal cancel: ' + (j.error || 'Unknown error'));
      }
    } catch (err) {
      alert('Error: ' + err.message);
    }
  });

  // Copy log to clipboard
  const copyBtn = document.getElementById('loop-job-copy-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      try {
        const text = logEl.textContent || '';
        if (navigator.clipboard && navigator.clipboard.writeText) {
          await navigator.clipboard.writeText(text);
        } else {
          const ta = document.createElement('textarea');
          ta.value = text;
          ta.style.position = 'absolute';
          ta.style.left = '-9999px';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
        }
        const originalText = copyBtn.textContent;
        copyBtn.textContent = 'Copied!';
        setTimeout(() => {
          copyBtn.textContent = originalText;
        }, 2000);
      } catch (err) {
        alert('Gagal menyalin log: ' + err.message);
      }
    });
  }

  dlg.addEventListener('click', function(e) {
    if (e.target === this) this.close();
  });
})();
</script>

<script>
(function() {
  const presetRadios = document.querySelectorAll('input[name="target_preset"]');
  const customRow = document.getElementById('custom-duration-row');
  const customInput = document.getElementById('custom_minutes');
  const sourceSelect = document.getElementById('source_video_id');
  const sourceThumb = document.getElementById('loop-source-thumb');
  const sourceEmpty = document.getElementById('loop-source-empty');
  const formError = document.getElementById('loop-form-error');

  function selectedTargetSeconds() {
    const checked = document.querySelector('input[name="target_preset"]:checked');
    if (!checked) return null;
    if (checked.value === 'custom') {
      const m = Number(customInput.value);
      if (!Number.isFinite(m) || m <= 0) return null;
      return Math.round(m * 60);
    }
    return Number(checked.dataset.seconds) || null;
  }

  function updateCustomVisibility() {
    if (!customRow) return;
    const customChecked = document.querySelector('input[name="target_preset"][value="custom"]');
    customRow.style.display = (customChecked && customChecked.checked) ? 'flex' : 'none';
  }

  function updateSourcePreview() {
    if (!sourceSelect) return;
    const opt = sourceSelect.selectedOptions[0];
    const hasVideo = opt && opt.value;
    const thumb = hasVideo ? opt.dataset.thumb : '';

    if (sourceThumb && sourceEmpty) {
      if (thumb) {
        sourceThumb.src = thumb;
        sourceThumb.style.display = 'block';
        sourceEmpty.style.display = 'none';
      } else {
        sourceThumb.removeAttribute('src');
        sourceThumb.style.display = 'none';
        sourceEmpty.style.display = 'flex';
      }
    }
    clearLoopError();
  }

  function showLoopError(message) {
    if (!formError) return;
    formError.textContent = message;
    formError.style.display = 'block';
  }

  function clearLoopError() {
    if (!formError) return;
    formError.textContent = '';
    formError.style.display = 'none';
  }

  presetRadios.forEach(r => r.addEventListener('change', () => {
    clearLoopError();
    updateCustomVisibility();
  }));
  if (customInput) customInput.addEventListener('input', () => {
    clearLoopError();
  });
  if (sourceSelect) sourceSelect.addEventListener('change', updateSourcePreview);

  // Crossfade slider — live update label and toggle visibility with smooth mode.
  const crossfadeSlider = document.getElementById('crossfade_seconds');
  const crossfadeValue = document.getElementById('crossfade-value');
  const crossfadeControl = document.getElementById('crossfade-control');
  const smoothCheck = document.getElementById('smooth');

  if (crossfadeSlider && crossfadeValue) {
    crossfadeSlider.addEventListener('input', () => {
      crossfadeValue.textContent = parseFloat(crossfadeSlider.value).toFixed(1);
    });
  }
  if (smoothCheck && crossfadeControl) {
    const updateCrossfadeVisibility = () => {
      crossfadeControl.style.opacity = smoothCheck.checked ? '1' : '0.4';
      if (crossfadeSlider) crossfadeSlider.disabled = !smoothCheck.checked;
    };
    smoothCheck.addEventListener('change', updateCrossfadeVisibility);
    updateCrossfadeVisibility();
  }

  // Modal tabs helper
  const createLoopModal = document.getElementById('create-loop');
  if (createLoopModal) {
    createLoopModal.querySelectorAll('.modal-tabs .tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;
        createLoopModal.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
        createLoopModal.querySelectorAll('.modal-tabs .tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const pnl = document.getElementById(target);
        if (pnl) pnl.classList.add('active');
      });
    });

    createLoopModal.addEventListener('close', () => {
      createLoopModal.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      createLoopModal.querySelectorAll('.modal-tabs .tab').forEach(t => t.classList.remove('active'));
      const defaultTab = createLoopModal.querySelector('.modal-tabs .tab[data-tab="loop-tab-video"]');
      if (defaultTab) defaultTab.classList.add('active');
      const defaultPanel = document.getElementById('loop-tab-video');
      if (defaultPanel) defaultPanel.classList.add('active');
    });
  }

  const form = document.getElementById('loop-form');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearLoopError();

      if (!sourceSelect.value) {
        showLoopError('Pilih video sumber dulu.');
        sourceSelect.focus();
        return;
      }
      const target = selectedTargetSeconds();
      if (!target) {
        showLoopError('Pilih target durasi.');
        if (customInput) customInput.focus();
        return;
      }
      const opt = sourceSelect.selectedOptions[0];
      const srcDur = opt ? Number(opt.dataset.duration) : null;
      if (srcDur && target < srcDur) {
        showLoopError('Target lebih pendek dari video sumber. Pilih durasi yang lebih panjang.');
        return;
      }

      // Submit form via fetch AJAX
      const submitBtn = form.querySelector('button[type="submit"]');
      if (submitBtn) submitBtn.disabled = true;
      
      try {
        const formData = new FormData(form);
        const searchParams = new URLSearchParams(formData);
        
        const r = await fetch(form.action || '/looper/start', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'Accept': 'application/json'
          },
          body: searchParams.toString()
        });
        
        const res = await r.json();
        if (!r.ok) throw new Error(res.error || 'Server error');
        
        // Success: close create-loop modal, reset form
        createLoopModal.close();
        form.reset();
        updateCustomVisibility();
        updateSourcePreview();
        
        // Open the monitoring detail modal with the returned jobId!
        if (res.jobId) {
          openLoopLog(res.jobId);
        } else {
          window.location.reload();
        }
      } catch (err) {
        showLoopError('Gagal memulai loop: ' + err.message);
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  }

  // Live poll active jobs every 2s.
  function formatEta(sec) {
    if (!sec || sec < 0) return '-';
    if (sec < 60) return sec + 's';
    if (sec < 3600) return Math.floor(sec / 60) + 'm ' + (sec % 60) + 's';
    const h = Math.floor(sec / 3600);
    const m = Math.floor((sec % 3600) / 60);
    return h + 'h ' + m + 'm';
  }

  // Live poll active jobs if there are any looping videos on the page
  const hasLoopingVideos = document.querySelector('.badge-idle') !== null;
  if (hasLoopingVideos) {
    setInterval(async () => {
      try {
        const r = await fetch('/looper/progress', { cache: 'no-store' });
        if (!r.ok) return;
        const data = await r.json();
        // If there are no active jobs left, but we had looping videos, reload to show ready/error status
        if (data.jobs.length === 0) {
          window.location.reload();
        }
      } catch (_) {}
    }, 4000);
  }

  // Init.
  updateCustomVisibility();
  updateSourcePreview();
})();
</script>

<!-- Modals script logic copied from videos.ejs -->
<script>
// Video preview player modal logic
(function() {
  const dlg = document.getElementById('video-preview');
  if (!dlg) return;
  const player = document.getElementById('preview-player');
  const titleEl = document.getElementById('preview-title');
  const infoEl = document.getElementById('preview-info');
  const errorEl = document.getElementById('preview-error');
  const captureBtn = document.getElementById('preview-capture-thumb');
  const downloadBtn = document.getElementById('preview-download-thumb');
  const statusEl = document.getElementById('preview-thumb-status');
  let currentVideoId = null;

  document.addEventListener('modal:before-open', (e) => {
    if (e.detail.id !== 'video-preview') return;
    const btn = e.detail.trigger;
    if (!btn) return;
    const src = btn.dataset.videoSrc || '';
    currentVideoId = btn.dataset.videoId || null;
    titleEl.textContent = btn.dataset.videoTitle || 'Preview';
    infoEl.textContent = btn.dataset.videoInfo || '';
    errorEl.style.display = 'none';
    player.style.display = 'block';
    player.src = src;
    player.load();
    statusEl.textContent = '';
    if (currentVideoId) {
      downloadBtn.href = '/videos/' + currentVideoId + '/thumb/download';
      downloadBtn.style.display = 'inline-flex';
      captureBtn.style.display = 'inline-flex';
    } else {
      downloadBtn.style.display = 'none';
      captureBtn.style.display = 'none';
    }
  });

  player.addEventListener('error', () => {
    player.style.display = 'none';
    errorEl.style.display = 'block';
  });

  dlg.addEventListener('close', () => {
    player.pause();
    player.removeAttribute('src');
    player.load();
    currentVideoId = null;
  });

  if (captureBtn) {
    captureBtn.addEventListener('click', async () => {
      if (!currentVideoId) return;
      const t = player.currentTime;
      if (!Number.isFinite(t)) {
        statusEl.textContent = 'Player belum siap.';
        return;
      }
      captureBtn.disabled = true;
      statusEl.textContent = `⏳ Capturing frame at ${t.toFixed(1)}s…`;
      try {
        const fd = new FormData();
        fd.append('at_second', t.toFixed(3));
        const r = await fetch('/videos/' + currentVideoId + '/regen-thumb', {
          method: 'POST',
          headers: { 'Accept': 'application/json' },
          body: fd,
        });
        if (!r.ok) throw new Error('HTTP ' + r.status);
        const j = await r.json();
        if (!j.ok) throw new Error(j.error || 'Failed');
        statusEl.textContent = `✓ Thumbnail updated (frame at ${t.toFixed(1)}s). Refresh library untuk lihat.`;
        document.querySelectorAll('img[src^="/videos/' + currentVideoId + '/thumb"]').forEach(img => {
          img.src = '/videos/' + currentVideoId + '/thumb?v=' + Date.now();
        });
      } catch (err) {
        statusEl.textContent = '✗ Gagal: ' + err.message;
      } finally {
        captureBtn.disabled = false;
      }
    });
  }
})();

// Edit video modal populate logic
document.addEventListener('modal:before-open', (e) => {
  if (e.detail.id !== 'edit-video') return;
  const btn = e.detail.trigger;
  if (!btn || !btn.dataset.videoId) return;
  document.getElementById('edit-video-form').action = '/videos/' + btn.dataset.videoId + '/edit';
  document.getElementById('edit-video-title').value = btn.dataset.videoTitle || '';
  document.getElementById('edit-video-folder').value = btn.dataset.folderId || '';
});

// YouTube Upload Modal logic
(function() {
  const form = document.getElementById('upload-youtube-form');
  if (!form) return;
  const dlg = document.getElementById('upload-youtube');
  const titleInput = document.getElementById('yt-upload-title');
  const privacyInput = document.getElementById('yt-upload-privacy');
  const categoryInput = document.getElementById('yt-upload-category');
  const progressDiv = document.getElementById('yt-upload-progress');
  const bar = document.getElementById('yt-upload-bar');
  const statusDiv = document.getElementById('yt-upload-status');
  const errorDiv = document.getElementById('yt-upload-error');
  const doneDiv = document.getElementById('yt-upload-done');
  const submitBtn = document.getElementById('yt-upload-submit-btn');
  const cancelBtn = document.getElementById('yt-upload-cancel-btn');
  const closeBtn = document.getElementById('yt-upload-close-btn');

  let currentVideoId = null;
  let activeJobId = null;
  let pollInterval = null;

  document.addEventListener('modal:before-open', (e) => {
    if (e.detail.id !== 'upload-youtube') return;
    const btn = e.detail.trigger;
    if (!btn) return;

    // Reset UI
    currentVideoId = btn.dataset.videoId;
    titleInput.value = btn.dataset.videoTitle || '';
    privacyInput.value = 'unlisted';
    categoryInput.value = '10';

    progressDiv.style.display = 'none';
    errorDiv.style.display = 'none';
    doneDiv.style.display = 'none';
    submitBtn.style.display = 'inline-flex';
    submitBtn.disabled = false;
    cancelBtn.style.display = 'none';
    closeBtn.disabled = false;

    // If click YouTube upload icon on an active job, resume watching progress
    const watchJob = btn.dataset.ytWatchJob;
    if (watchJob) {
      activeJobId = watchJob;
      startPolling();
    }
  });

  dlg.addEventListener('close', () => {
    stopPolling();
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!currentVideoId) return;

    submitBtn.disabled = true;
    errorDiv.style.display = 'none';
    progressDiv.style.display = 'block';
    bar.style.width = '0%';
    statusDiv.textContent = 'Memulai upload...';
    closeBtn.disabled = true;

    try {
      const r = await fetch('/youtube/upload/' + currentVideoId, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          title: titleInput.value,
          privacy: privacyInput.value,
          category_id: categoryInput.value,
        }),
      });
      const res = await r.json();
      if (!r.ok) throw new Error(res.error || 'Request failed');

      activeJobId = res.jobId;
      startPolling();
    } catch (err) {
      errorDiv.textContent = 'Gagal upload: ' + err.message;
      errorDiv.style.display = 'block';
      submitBtn.disabled = false;
      closeBtn.disabled = false;
    }
  });

  if (cancelBtn) {
    cancelBtn.addEventListener('click', async () => {
      if (!activeJobId) return;
      if (!confirm('Cancel upload ke YouTube?')) return;
      cancelBtn.disabled = true;
      try {
        await fetch('/youtube/upload/jobs/' + activeJobId + '/cancel', { method: 'POST' });
        stopPolling();
        progressDiv.style.display = 'none';
        errorDiv.textContent = 'Upload dibatalkan.';
        errorDiv.style.display = 'block';
        submitBtn.style.display = 'inline-flex';
        submitBtn.disabled = false;
        cancelBtn.style.display = 'none';
        closeBtn.disabled = false;
      } catch (err) {
        alert('Gagal cancel: ' + err.message);
        cancelBtn.disabled = false;
      }
    });
  }

  function startPolling() {
    submitBtn.style.display = 'none';
    cancelBtn.style.display = 'inline-flex';
    cancelBtn.disabled = false;
    progressDiv.style.display = 'block';
    closeBtn.disabled = true;

    stopPolling();
    pollInterval = setInterval(async () => {
      try {
        const r = await fetch('/youtube/upload/jobs/' + activeJobId);
        if (!r.ok) {
          if (r.status === 404) {
            stopPolling();
            errorDiv.textContent = 'Job tidak ditemukan.';
            errorDiv.style.display = 'block';
            resetToStart();
          }
          return;
        }
        const job = await r.json();
        bar.style.width = (job.percent || 0) + '%';
        statusDiv.textContent = `Uploading: ${job.percent || 0}% (${job.status})`;

        if (job.status === 'completed') {
          stopPolling();
          progressDiv.style.display = 'none';
          doneDiv.innerHTML = `✓ Upload selesai! Video ID: <a href="https://youtu.be/${job.youtubeVideoId}" target="_blank" style="color:var(--accent);text-decoration:underline;">${job.youtubeVideoId}</a>`;
          doneDiv.style.display = 'block';
          cancelBtn.style.display = 'none';
          closeBtn.disabled = false;
          // Refresh list to update YT badges
          setTimeout(() => window.location.reload(), 1500);
        } else if (job.status === 'error') {
          stopPolling();
          progressDiv.style.display = 'none';
          errorDiv.textContent = 'Upload gagal: ' + (job.lastError || 'Unknown error');
          errorDiv.style.display = 'block';
          resetToStart();
        }
      } catch (err) {
        console.error('Error polling job:', err);
      }
    }, 1500);
  }

  function stopPolling() {
    if (pollInterval) {
      clearInterval(pollInterval);
      pollInterval = null;
    }
  }

  function resetToStart() {
    submitBtn.style.display = 'inline-flex';
    submitBtn.disabled = false;
    cancelBtn.style.display = 'none';
    closeBtn.disabled = false;
  }
})();
</script>

