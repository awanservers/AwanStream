<%- include('partials/header', {
  title: 'Single Video Streams',
  activeNav: 'streams',
  pageTitle: 'Streams — Single Video',
  pageSubtitle: 'Stream satu video ke RTMP (loop atau sekali putar).',
  topbarActions: `
    <button type="button" class="btn btn-primary" data-open-modal="new-stream">+ New stream</button>
  `,
}) %>
<%- include('partials/flash', { error, notice }) %>
<% const streamTzLabel = typeof tzLabel !== 'undefined' ? tzLabel : 'WIB'; %>

<% if (streams.length === 0) { %>
  <div class="card empty">
    <p class="muted">Belum ada stream single video.</p>
    <button type="button" class="btn btn-primary" data-open-modal="new-stream">+ Buat stream pertama</button>
  </div>
<% } else { %>
  <div class="table-wrap card card-flush">
    <table class="table">
      <thead><tr>
        <th class="col-w-title">Name</th>
        <th class="col-w-title">Video</th>
        <th class="col-w-platform">Platform</th>
        <th class="col-w-status">Status</th>
        <th class="col-w-date">Last run</th>
        <th class="col-w-actions">Actions</th>
      </tr></thead>
      <tbody>
        <% streams.forEach(s => { %>
          <tr>
            <td class="truncate" title="<%= s.name %>"><%= s.name %></td>
            <td class="truncate" title="<%= s.video_title || '(missing)' %>"><%= s.video_title || '(missing)' %></td>
            <td><%= presets[s.platform] ? presets[s.platform].label : s.platform %></td>
            <td>
              <span class="badge badge-<%= s.status %>"><%= s.status %></span>
              <% if (s.next_start_at) { %>
                <div class="small muted">
                  Scheduled <%= formatTimeShort(s.next_start_at) %><% if (s.next_stop_at) { %> - <%= formatTimeShort(s.next_stop_at) %><% } %>
                </div>
              <% } %>
              <% if (s.last_error) { %><div class="small muted"><%= s.last_error %></div><% } %>
            </td>
            <td class="col-date small muted">
              <% if (s.status === 'running') { %>
                <span class="stream-timer" data-started-at="<%= s.started_at %>">started <%= formatTime(s.started_at) %></span>
              <% } else if (s.stopped_at) { %>
                <%= formatTime(s.stopped_at) %>
              <% } else { %>-<% } %>
            </td>
            <td class="actions">
              <% if (s.status === 'running') { %>
                <form method="POST" action="/streams/<%= s.id %>/stop" class="inline">
                  <button class="btn-icon btn-icon-warn" type="submit" title="Stop stream">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="1"/></svg>
                  </button>
                </form>
              <% } else { %>
                <form method="POST" action="/streams/<%= s.id %>/start" class="inline">
                  <button class="btn-icon btn-icon-primary" type="submit" title="Start stream">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                  </button>
                </form>
              <% } %>
              <button type="button" class="btn-icon"
                      data-open-modal="edit-stream"
                      data-stream-id="<%= s.id %>"
                      data-stream-name="<%= s.name %>"
                      data-stream-video-id="<%= s.video_id %>"
                      data-stream-platform="<%= s.platform %>"
                      data-stream-rtmp-url="<%= s.rtmp_url %>"
                      data-stream-loop="<%= s.loop_video %>"
                      data-stream-re-encode="<%= s.re_encode %>"
                      data-stream-bitrate="<%= s.video_bitrate || '4500k' %>"
                      data-stream-keyframe="<%= s.keyframe_interval || 2 %>"
                      data-stream-preset="<%= s.preset || 'veryfast' %>"
                      data-stream-audio-id="<%= s.audio_id || '' %>"
                      data-stream-audio-volume="<%= s.audio_volume || '0.3' %>"
                      data-stream-audio-mode="<%= s.audio_mode || 'mix' %>"
                      data-stream-scheduled="<%= s.next_start_at ? '1' : '0' %>"
                      data-stream-start-at="<%= s.next_start_at ? formatUTCToLocalInput(s.next_start_at) : '' %>"
                      data-stream-stop-at="<%= s.next_stop_at ? formatUTCToLocalInput(s.next_stop_at) : '' %>"
                      title="Edit">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </button>
              <button type="button" class="btn-icon"
                      data-open-modal="stream-log"
                      data-stream-id="<%= s.id %>"
                      data-stream-name="<%= s.name %>"
                      data-stream-status="<%= s.status %>"
                      title="View log">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
              </button>
              <form method="POST" action="/streams/<%= s.id %>/delete" class="inline"
                    data-confirm="Hapus stream '<%= s.name %>'?"
                    data-confirm-title="Hapus stream"
                    data-confirm-action="Hapus">
                <button class="btn-icon btn-icon-danger" type="submit" title="Delete">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                </button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<dialog id="new-stream" class="modal modal-xl">
  <div class="modal-card">
    <header class="modal-header">
      <h2>New stream — Single Video</h2>
      <button type="button" class="modal-close" data-close-modal aria-label="Close">×</button>
    </header>
    <% if (videos.length === 0) { %>
      <div class="modal-body">
        <p class="muted">Belum ada video ready. <a href="/videos">Upload & Prepare</a> dulu.</p>
      </div>
      <footer class="modal-footer">
        <a href="/videos" class="btn btn-primary">Ke Videos</a>
        <button type="button" class="btn" data-close-modal>Tutup</button>
      </footer>
    <% } else { %>
      <form method="POST" action="/streams">
        <input type="hidden" name="re_encode" value="0">
        <div class="modal-tabs">
          <button type="button" class="tab active" data-tab="new-single-stream-tab">Stream</button>
          <button type="button" class="tab" data-tab="new-single-schedule-tab">Schedule</button>
          <button type="button" class="tab" data-tab="new-single-audio-tab">Audio</button>
        </div>
        <div class="modal-body">
          <div id="new-single-stream-tab" class="tab-panel active">
            <div class="stream-create-layout">
              <div class="stream-create-fields">
                <label>Name <input name="name" required placeholder="My live stream"></label>
                <label>Video
                <select name="video_id" id="new-single-video-select" required>
                  <% videos.forEach(v => { %>
                    <option value="<%= v.id %>" data-thumb="<%= v.thumbnail ? '/videos/' + v.id + '/thumb' : '' %>"><%= v.title %></option>
                  <% }) %>
                </select>
              </label>
              <label>Platform
                <select name="platform" id="platform-select" required>
                  <option value="" disabled selected>Select platform...</option>
                  <% Object.keys(presets).forEach(p => { %>
                    <option value="<%= p %>" data-url="<%= presets[p].url %>"><%= presets[p].label %></option>
                  <% }) %>
                </select>
              </label>
            </div>
            <div class="stream-video-preview" id="new-single-video-preview">
              <img id="new-single-video-thumb" alt="" loading="lazy" style="display:none">
              <div class="stream-video-preview-empty" id="new-single-video-empty">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="14" height="14" rx="2"/><path d="M22 7l-6 5 6 5V7z"/></svg>
              </div>
            </div>
              <label>RTMP URL <input name="rtmp_url" id="rtmp-url" required placeholder="rtmp://..."></label>
              <label>Stream key
                <div class="input-with-toggle">
                  <input type="password" name="stream_key" id="new-stream-key" required placeholder="xxxx-xxxx-xxxx" autocomplete="off">
                  <button type="button" class="input-toggle" data-toggle-input="new-stream-key" aria-label="Show/hide stream key">
                    <svg class="eye-show" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    <svg class="eye-hide" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                  </button>
                </div>
              </label>
              <label class="full inline-check">
                <input type="checkbox" name="loop_video" value="1" checked>
                Loop video terus-menerus
              </label>
            </div>
          </div>
          <div id="new-single-schedule-tab" class="tab-panel">
            <div class="grid-2">
              <label class="full inline-check">
                <input type="checkbox" name="schedule_enabled" value="1" data-schedule-toggle="new-single">
                Jadwalkan stream ini
              </label>
              <label>Start at <input type="datetime-local" name="start_at" data-schedule-field="new-single" disabled></label>
              <label>Stop at <input type="datetime-local" name="stop_at" data-schedule-field="new-single" disabled></label>
              <div class="full small muted">Timezone: <%= streamTzLabel %></div>
            </div>
          </div>
          <div id="new-single-audio-tab" class="tab-panel">
            <div class="grid-2">
              <label class="full">Audio overlay <span class="muted small">(opsional, musik background)</span>
                <select name="audio_id">
                  <option value="">Tanpa audio overlay</option>
                  <% audioFiles.forEach(a => { %>
                    <option value="<%= a.id %>"><%= a.title %></option>
                  <% }) %>
                </select>
              </label>
              <label>Volume overlay <span class="muted small">(0.0 - 2.0+; 1.0 = normal, >1.0 = amplifikasi)</span>
                <input type="number" name="audio_volume" value="0.3" min="0" max="10" step="0.1" style="max-width:100px;">
              </label>
              <label>Mode audio overlay <span class="muted small">(Mix vs Replace)</span>
                <select name="audio_mode">
                  <option value="mix" selected>Mix (Gabung suara video + musik)</option>
                  <option value="replace">Replace (Ganti suara video dengan musik sepenuhnya)</option>
                </select>
              </label>
            </div>
          </div>
        </div>
        <footer class="modal-footer">
          <button type="button" class="btn" data-close-modal>Batal</button>
          <button type="submit" class="btn btn-primary">Simpan</button>
        </footer>
      </form>
      <script>
        (function(){
          const sel = document.getElementById('platform-select');
          const url = document.getElementById('rtmp-url');
          if (sel && url) sel.addEventListener('change', () => { const u = sel.options[sel.selectedIndex].dataset.url; if (u) url.value = u; });
          const videoSelect = document.getElementById('new-single-video-select');
          const videoThumb = document.getElementById('new-single-video-thumb');
          const videoEmpty = document.getElementById('new-single-video-empty');
          function syncVideoPreview() {
            if (!videoSelect || !videoThumb || !videoEmpty) return;
            const opt = videoSelect.options[videoSelect.selectedIndex];
            const thumb = opt ? opt.dataset.thumb : '';
            if (thumb) {
              videoThumb.src = thumb;
              videoThumb.style.display = '';
              videoEmpty.style.display = 'none';
            } else {
              videoThumb.removeAttribute('src');
              videoThumb.style.display = 'none';
              videoEmpty.style.display = 'flex';
            }
          }
          if (videoSelect) {
            videoSelect.addEventListener('change', syncVideoPreview);
            syncVideoPreview();
          }
          const modal = document.getElementById('new-stream');
          if (modal) {
            modal.querySelectorAll('.modal-tabs .tab').forEach((tab) => {
              tab.addEventListener('click', () => {
                const target = tab.dataset.tab;
                modal.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
                modal.querySelectorAll('.modal-tabs .tab').forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                const panel = document.getElementById(target);
                if (panel) panel.classList.add('active');
              });
            });
          }
          const scheduleToggle = document.querySelector('[data-schedule-toggle="new-single"]');
          const scheduleFields = document.querySelectorAll('[data-schedule-field="new-single"]');
          function syncScheduleFields() {
            scheduleFields.forEach((field) => {
              field.disabled = !scheduleToggle.checked;
              if (!scheduleToggle.checked) field.value = '';
            });
          }
          if (scheduleToggle) {
            scheduleToggle.addEventListener('change', syncScheduleFields);
            syncScheduleFields();
          }
        })();
      </script>
    <% } %>
  </div>
</dialog>

<!-- Edit stream modal -->
<% if (videos.length > 0) { %>
<dialog id="edit-stream" class="modal modal-xl">
  <div class="modal-card">
    <header class="modal-header">
      <h2>Edit stream — Single Video</h2>
      <button type="button" class="modal-close" data-close-modal aria-label="Close">×</button>
    </header>
    <form method="POST" id="edit-stream-form">
      <input type="hidden" name="re_encode" id="edit-re-encode" value="0">
      <div class="modal-tabs">
        <button type="button" class="tab active" data-tab="edit-single-stream-tab">Stream</button>
        <button type="button" class="tab" data-tab="edit-single-schedule-tab">Schedule</button>
        <button type="button" class="tab" data-tab="edit-single-audio-tab">Audio</button>
      </div>
      <div class="modal-body">
        <div id="edit-single-stream-tab" class="tab-panel active">
          <div class="stream-create-layout">
            <div class="stream-create-fields">
          <label>Name <input name="name" id="edit-stream-name" required></label>
          <label>Video
            <select name="video_id" id="edit-stream-video" required>
              <% videos.forEach(v => { %>
                <option value="<%= v.id %>" data-thumb="<%= v.thumbnail ? '/videos/' + v.id + '/thumb' : '' %>"><%= v.title %></option>
              <% }) %>
            </select>
          </label>
          <label>Platform
            <select name="platform" id="edit-stream-platform" required>
              <% Object.keys(presets).forEach(p => { %>
                <option value="<%= p %>" data-url="<%= presets[p].url %>"><%= presets[p].label %></option>
              <% }) %>
            </select>
          </label>
        </div>
        <div class="stream-video-preview" id="edit-single-video-preview">
          <img id="edit-single-video-thumb" alt="" loading="lazy" style="display:none">
          <div class="stream-video-preview-empty" id="edit-single-video-empty">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="14" height="14" rx="2"/><path d="M22 7l-6 5 6 5V7z"/></svg>
          </div>
        </div>
          <label>RTMP URL <input name="rtmp_url" id="edit-stream-rtmp" required></label>
          <label class="full">Stream key
            <div class="input-with-toggle">
              <input type="password" name="stream_key" id="edit-stream-key" autocomplete="off" placeholder="Kosongkan kalau tidak diganti">
              <button type="button" class="input-toggle" data-toggle-input="edit-stream-key" aria-label="Show/hide stream key">
                <svg class="eye-show" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                <svg class="eye-hide" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
              </button>
            </div>
          </label>
          <label class="full inline-check">
            <input type="checkbox" name="loop_video" value="1" id="edit-stream-loop">
            Loop video terus-menerus
          </label>
        </div>
      </div>
      <div id="edit-single-schedule-tab" class="tab-panel">
        <div class="grid-2">
          <label class="full inline-check">
            <input type="checkbox" name="schedule_enabled" value="1" id="edit-stream-schedule-enabled" data-schedule-toggle="edit-single">
            Jadwalkan stream ini
          </label>
          <label>Start at <input type="datetime-local" name="start_at" id="edit-stream-start-at" data-schedule-field="edit-single" disabled></label>
          <label>Stop at <input type="datetime-local" name="stop_at" id="edit-stream-stop-at" data-schedule-field="edit-single" disabled></label>
          <div class="full small muted">Timezone: <%= streamTzLabel %></div>
        </div>
      </div>
      <div id="edit-single-audio-tab" class="tab-panel">
        <div class="grid-2">
          <label class="full">Audio overlay <span class="muted small">(opsional)</span>
            <select name="audio_id" id="edit-stream-audio-id">
              <option value="">— Tanpa audio overlay —</option>
              <% audioFiles.forEach(a => { %>
                <option value="<%= a.id %>"><%= a.title %></option>
              <% }) %>
            </select>
          </label>
          <label>Volume overlay <span class="muted small">(1.0 = normal, >1.0 = amplifikasi)</span>
            <input type="number" name="audio_volume" id="edit-stream-audio-volume" value="0.3" min="0" max="10" step="0.1" style="max-width:100px;">
          </label>
          <label>Mode audio overlay
            <select name="audio_mode" id="edit-stream-audio-mode">
              <option value="mix">Mix (Gabung suara video + musik)</option>
              <option value="replace">Replace (Ganti suara video dengan musik sepenuhnya)</option>
            </select>
          </label>
        </div>
      </div>
    </div>
      <footer class="modal-footer">
        <button type="button" class="btn" data-close-modal>Batal</button>
        <button type="submit" class="btn btn-primary">Save</button>
      </footer>
    </form>
  </div>
</dialog>
<script>
(function() {
  const platSel = document.getElementById('edit-stream-platform');
  const rtmpInput = document.getElementById('edit-stream-rtmp');
  if (platSel && rtmpInput) {
    platSel.addEventListener('change', () => {
      const u = platSel.options[platSel.selectedIndex].dataset.url;
      if (u) rtmpInput.value = u;
    });
  }

  const videoSelect = document.getElementById('edit-stream-video');
  const videoThumb = document.getElementById('edit-single-video-thumb');
  const videoEmpty = document.getElementById('edit-single-video-empty');
  function syncVideoPreview() {
    if (!videoSelect || !videoThumb || !videoEmpty) return;
    const opt = videoSelect.options[videoSelect.selectedIndex];
    const thumb = opt ? opt.dataset.thumb : '';
    if (thumb) {
      videoThumb.src = thumb;
      videoThumb.style.display = '';
      videoEmpty.style.display = 'none';
    } else {
      videoThumb.removeAttribute('src');
      videoThumb.style.display = 'none';
      videoEmpty.style.display = 'flex';
    }
  }
  if (videoSelect) {
    videoSelect.addEventListener('change', syncVideoPreview);
  }

  const modal = document.getElementById('edit-stream');
  if (modal) {
    modal.querySelectorAll('.modal-tabs .tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;
        modal.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
        modal.querySelectorAll('.modal-tabs .tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const panel = document.getElementById(target);
        if (panel) panel.classList.add('active');
      });
    });
  }

  const scheduleToggle = document.getElementById('edit-stream-schedule-enabled');
  const scheduleFields = document.querySelectorAll('[data-schedule-field="edit-single"]');
  function syncScheduleFields() {
    scheduleFields.forEach((field) => {
      field.disabled = !scheduleToggle.checked;
      if (!scheduleToggle.checked) field.value = '';
    });
  }
  if (scheduleToggle) {
    scheduleToggle.addEventListener('change', syncScheduleFields);
  }
  document.addEventListener('modal:before-open', (e) => {
    if (e.detail.id !== 'edit-stream') return;
    const btn = e.detail.trigger;
    if (!btn) return;
    document.getElementById('edit-stream-form').action = '/streams/' + btn.dataset.streamId + '/edit';
    document.getElementById('edit-stream-name').value = btn.dataset.streamName || '';
    document.getElementById('edit-stream-video').value = btn.dataset.streamVideoId || '';
    syncVideoPreview();
    document.getElementById('edit-stream-platform').value = btn.dataset.streamPlatform || 'custom';
    document.getElementById('edit-stream-rtmp').value = btn.dataset.streamRtmpUrl || '';
    const keyInput = document.getElementById('edit-stream-key');
    keyInput.value = '';
    keyInput.type = 'password';
    const keyToggle = document.querySelector('[data-toggle-input="edit-stream-key"]');
    if (keyToggle) {
      const showIcon = keyToggle.querySelector('.eye-show');
      const hideIcon = keyToggle.querySelector('.eye-hide');
      if (showIcon) showIcon.style.display = '';
      if (hideIcon) hideIcon.style.display = 'none';
    }
    document.getElementById('edit-stream-loop').checked = btn.dataset.streamLoop === '1';
    document.getElementById('edit-re-encode').value = btn.dataset.streamReEncode || '0';
    document.getElementById('edit-stream-audio-id').value = btn.dataset.streamAudioId || '';
    document.getElementById('edit-stream-audio-volume').value = btn.dataset.streamAudioVolume || '0.3';
    document.getElementById('edit-stream-audio-mode').value = btn.dataset.streamAudioMode || 'mix';
    const isScheduled = btn.dataset.streamScheduled === '1';
    scheduleToggle.checked = isScheduled;
    document.getElementById('edit-stream-start-at').value = btn.dataset.streamStartAt || '';
    document.getElementById('edit-stream-stop-at').value = btn.dataset.streamStopAt || '';
    syncScheduleFields();

    if (modal) {
      modal.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      modal.querySelectorAll('.modal-tabs .tab').forEach(t => t.classList.remove('active'));
      const defaultTab = modal.querySelector('.modal-tabs .tab[data-tab="edit-single-stream-tab"]');
      if (defaultTab) defaultTab.classList.add('active');
      const defaultPanel = document.getElementById('edit-single-stream-tab');
      if (defaultPanel) defaultPanel.classList.add('active');
    }
  });
})();
</script>
<% } %>

<!-- Stream log modal -->
<dialog id="stream-log" class="modal modal-lg">
  <div class="modal-card">
    <header class="modal-header">
      <h2>Log: <span id="stream-log-name">…</span></h2>
      <button type="button" class="modal-close" data-close-modal aria-label="Close">×</button>
    </header>
    <div class="modal-body">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;gap:0.5rem;flex-wrap:wrap">
        <span class="small muted" id="stream-log-status">Loading…</span>
        <div style="display:flex;gap:0.75rem;align-items:center">
          <span class="small muted" id="stream-log-lines">—</span>
          <label class="inline-check small" style="margin:0">
            <input type="checkbox" id="stream-log-autoscroll" checked>
            Auto-scroll
          </label>
        </div>
      </div>
      <pre class="log-box" id="stream-log-content" style="max-height:400px">Loading…</pre>
    </div>
    <footer class="modal-footer">
      <button type="button" class="btn" id="stream-log-copy" title="Copy log ke clipboard">📋 Copy</button>
      <button type="button" class="btn" id="stream-log-refresh">Refresh</button>
      <button type="button" class="btn" data-close-modal>Close</button>
    </footer>
  </div>
</dialog>
<script>
(function() {
  const dlg = document.getElementById('stream-log');
  if (!dlg) return;
  const nameEl = document.getElementById('stream-log-name');
  const statusEl = document.getElementById('stream-log-status');
  const linesEl = document.getElementById('stream-log-lines');
  const contentEl = document.getElementById('stream-log-content');
  const autoscrollEl = document.getElementById('stream-log-autoscroll');
  const refreshBtn = document.getElementById('stream-log-refresh');
  const copyBtn = document.getElementById('stream-log-copy');
  const TAIL_LINES = 80;
  let currentStreamId = null;
  let pollTimer = null;
  let isRunning = false;

  async function fetchLog() {
    if (!currentStreamId) return;
    try {
      const r = await fetch('/streams/' + currentStreamId + '/log?lines=' + TAIL_LINES, { cache: 'no-store' });
      if (!r.ok) {
        statusEl.textContent = 'Failed to load log (' + r.status + ')';
        return;
      }
      const text = await r.text();
      const wasAtBottom = contentEl.scrollHeight - contentEl.scrollTop - contentEl.clientHeight < 20;
      contentEl.textContent = text || '(log empty)';
      const lineCount = text ? text.split('\n').filter(Boolean).length : 0;
      linesEl.textContent = 'Showing last ' + lineCount + ' line' + (lineCount === 1 ? '' : 's');
      if (autoscrollEl.checked && (wasAtBottom || contentEl.textContent === '(log empty)')) {
        contentEl.scrollTop = contentEl.scrollHeight;
      }
      statusEl.textContent = isRunning
        ? '🔴 Live · auto-refresh 3s'
        : 'Last log (stream idle)';
    } catch (err) {
      statusEl.textContent = 'Network error';
    }
  }

  document.addEventListener('modal:before-open', (e) => {
    if (e.detail.id !== 'stream-log') return;
    const btn = e.detail.trigger;
    if (!btn) return;
    currentStreamId = btn.dataset.streamId;
    nameEl.textContent = btn.dataset.streamName || '';
    isRunning = btn.dataset.streamStatus === 'running';
    statusEl.textContent = 'Loading…';
    contentEl.textContent = 'Loading…';
    linesEl.textContent = '—';
    fetchLog();
    if (pollTimer) clearInterval(pollTimer);
    if (isRunning) pollTimer = setInterval(fetchLog, 3000);
  });

  dlg.addEventListener('close', () => {
    if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
    currentStreamId = null;
  });

  refreshBtn.addEventListener('click', fetchLog);

  copyBtn.addEventListener('click', () => {
    const text = contentEl.textContent || '';
    if (!text || text === '(log empty)' || text === 'Loading…') return;
    const original = copyBtn.textContent;
    // Select text inside <pre> element and copy via Selection API (works on HTTP).
    const range = document.createRange();
    range.selectNodeContents(contentEl);
    const sel = window.getSelection();
    sel.removeAllRanges();
    sel.addRange(range);
    let ok = false;
    try { ok = document.execCommand('copy'); } catch (_) {}
    sel.removeAllRanges();
    if (!ok) {
      // Last resort: try Clipboard API (only works on HTTPS/localhost).
      try { navigator.clipboard.writeText(text); ok = true; } catch (_) {}
    }
    copyBtn.textContent = ok ? '✓ Copied' : '✗ Failed';
    setTimeout(() => { copyBtn.textContent = original; }, 1500);
  });
})();
</script>

<script>
// Live duration timer for running streams.
(function () {
  function fmtDuration(sec) {
    const d = Math.floor(sec / 86400);
    const h = Math.floor((sec % 86400) / 3600);
    const m = Math.floor((sec % 3600) / 60);
    const s = Math.floor(sec % 60);
    if (d > 0) return d + 'd ' + h + 'h ' + m + 'm';
    if (h > 0) return h + 'h ' + m + 'm ' + s + 's';
    return m + 'm ' + s + 's';
  }
  function update() {
    document.querySelectorAll('.stream-timer[data-started-at]').forEach(el => {
      const raw = el.dataset.startedAt;
      if (!raw) return;
      const iso = raw.includes('T') ? raw : raw.replace(' ', 'T') + 'Z';
      const startMs = new Date(iso).getTime();
      if (Number.isNaN(startMs)) return;
      const elapsed = Math.max(0, Math.floor((Date.now() - startMs) / 1000));
      el.innerHTML = '🔴 <strong>' + fmtDuration(elapsed) + '</strong>';
    });
  }
  if (document.querySelectorAll('.stream-timer').length > 0) {
    update();
    setInterval(update, 1000);
  }
})();
</script>
<%- include('partials/footer') %>
