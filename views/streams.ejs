<%- include('partials/header', {
  title: 'Streams',
  activeNav: 'streams',
  pageTitle: 'Streams',
  pageSubtitle: 'Konfigurasi dan kontrol live streaming ke RTMP.',
  topbarActions: `
    <button type="button" class="btn btn-primary" data-open-modal="new-stream">+ New stream</button>
  `,
}) %>
<%- include('partials/flash', { error, notice }) %>

<% if (streams.length === 0) { %>
  <div class="card empty">
    <p class="muted">Belum ada stream.</p>
    <button type="button" class="btn btn-primary" data-open-modal="new-stream">+ Buat stream pertama</button>
  </div>
<% } else { %>
  <div class="table-wrap card card-flush">
    <table class="table">
      <thead><tr>
        <th class="col-w-title">Name</th>
        <th class="col-w-title">Video</th>
        <th class="col-w-platform">Platform</th>
        <th class="col-w-status">Status</th>
        <th class="col-w-date">Last run</th>
        <th class="col-w-actions">Actions</th>
      </tr></thead>
      <tbody>
        <% streams.forEach(s => { %>
          <tr>
            <td class="truncate" title="<%= s.name %>"><%= s.name %></td>
            <td class="truncate" title="<%= s.video_title || '(missing)' %>">
              <%= s.playlist_name ? '📋 ' + s.playlist_name : (s.video_title || '(missing)') %>
            </td>
            <td><%= s.platform %></td>
            <td>
              <span class="badge badge-<%= s.status %>"><%= s.status %></span>
              <% if (s.last_error) { %>
                <div class="small muted"><%= s.last_error %></div>
              <% } %>
            </td>
            <td class="col-date small muted">
              <% if (s.status === 'running') { %>
                started <%= formatTime(s.started_at) %>
              <% } else if (s.stopped_at) { %>
                last run <%= formatTime(s.started_at) %><br/>
                stopped <%= formatTime(s.stopped_at) %>
              <% } else { %>
                -
              <% } %>
            </td>
            <td class="actions">
              <% if (s.status === 'running') { %>
                <form method="POST" action="/streams/<%= s.id %>/stop" class="inline">
                  <button class="btn btn-warn" type="submit">Stop</button>
                </form>
              <% } else { %>
                <form method="POST" action="/streams/<%= s.id %>/start" class="inline">
                  <button class="btn btn-primary" type="submit">Start</button>
                </form>
              <% } %>
              <a class="btn btn-link" href="/streams/<%= s.id %>/log" target="_blank">Log</a>
              <form method="POST" action="/streams/<%= s.id %>/delete" class="inline"
                    data-confirm="Hapus stream '<%= s.name %>'? Konfigurasi dan log-nya tidak bisa dikembalikan."
                    data-confirm-title="Hapus stream"
                    data-confirm-action="Hapus">
                <button class="btn btn-danger" type="submit">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<dialog id="new-stream" class="modal">
  <div class="modal-card">
    <header class="modal-header">
      <h2>New stream</h2>
      <button type="button" class="modal-close" data-close-modal aria-label="Close">×</button>
    </header>
    <% const readyVideos = videos.filter(v => v.status === 'ready'); %>
    <% if (readyVideos.length === 0 && playlists.length === 0) { %>
      <div class="modal-body">
        <p class="muted">Belum ada video yang siap streaming.</p>
        <p class="muted small">Upload video di <a href="/videos">Videos</a>, lalu klik <strong>Prepare</strong> untuk transcode jadi stream-ready. Atau buat <a href="/playlists">Playlist</a> dulu.</p>
      </div>
      <footer class="modal-footer">
        <a href="/videos" class="btn btn-primary">Ke halaman Videos</a>
        <button type="button" class="btn" data-close-modal>Tutup</button>
      </footer>
    <% } else { %>
      <form method="POST" action="/streams">
        <input type="hidden" name="re_encode" value="0">
        <div class="modal-body">
          <div class="grid-2">
            <label>Name <input name="name" required placeholder="My live stream"></label>
            <label>Source
              <select name="source_type" id="source-type">
                <option value="video" selected>Single video</option>
                <% if (playlists.length > 0) { %>
                  <option value="playlist">Playlist (sequential)</option>
                <% } %>
              </select>
            </label>
            <label id="video-select-label">Video
              <select name="video_id" id="video-select">
                <% readyVideos.forEach(v => { %>
                  <option value="<%= v.id %>"><%= v.title %></option>
                <% }) %>
              </select>
            </label>
            <label id="playlist-select-label" style="display:none">Playlist
              <select name="playlist_id" id="playlist-select">
                <% playlists.forEach(p => { %>
                  <option value="<%= p.id %>"><%= p.name %> (<%= p.item_count %> videos)</option>
                <% }) %>
              </select>
            </label>
            <label>Platform
              <select name="platform" id="platform-select">
                <% Object.keys(presets).forEach(p => { %>
                  <option value="<%= p %>" data-url="<%= presets[p] %>"><%= p %></option>
                <% }) %>
              </select>
            </label>
            <label>RTMP URL <input name="rtmp_url" id="rtmp-url" required placeholder="rtmp://..."></label>
            <label class="full">Stream key <input name="stream_key" required placeholder="xxxx-xxxx-xxxx"></label>
            <label class="full inline-check">
              <input type="checkbox" name="loop_video" value="1" checked>
              Loop (single video: loop file, playlist: loop setelah video terakhir)
            </label>
          </div>
        </div>
        <footer class="modal-footer">
          <button type="button" class="btn" data-close-modal>Batal</button>
          <button type="submit" class="btn btn-primary">Simpan</button>
        </footer>
      </form>
      <script>
        (function(){
          const sel = document.getElementById('platform-select');
          const url = document.getElementById('rtmp-url');
          if (sel && url) {
            sel.addEventListener('change', () => {
              const u = sel.options[sel.selectedIndex].dataset.url;
              if (u) url.value = u;
            });
          }
          // Toggle video vs playlist select.
          const srcType = document.getElementById('source-type');
          const vidLabel = document.getElementById('video-select-label');
          const plLabel = document.getElementById('playlist-select-label');
          if (srcType) {
            srcType.addEventListener('change', () => {
              if (srcType.value === 'playlist') {
                vidLabel.style.display = 'none';
                plLabel.style.display = '';
              } else {
                vidLabel.style.display = '';
                plLabel.style.display = 'none';
              }
            });
          }
        })();
      </script>
    <% } %>
  </div>
</dialog>

<%- include('partials/footer') %>
