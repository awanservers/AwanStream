<%- include('partials/header', {
  title: 'History',
  activeNav: 'history',
  pageTitle: 'Stream History',
  pageSubtitle: 'Riwayat semua sesi streaming yang sudah selesai.',
}) %>
<%- include('partials/flash', { error: error, notice: notice }) %>

<% if (history.length === 0) { %>
  <div class="card empty">
    <p class="muted">Belum ada riwayat streaming. History akan tercatat otomatis setelah stream berjalan minimal 10 detik.</p>
  </div>
<% } else { %>
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.75rem">
    <p class="muted small"><%= history.length %> entries</p>
    <form method="POST" action="/history/clear"
          data-confirm="Hapus semua riwayat streaming?"
          data-confirm-title="Clear History"
          data-confirm-action="Hapus Semua">
      <button type="submit" class="btn btn-sm btn-danger">Clear All</button>
    </form>
  </div>
  <div class="table-wrap card card-flush">
    <table class="table">
      <thead><tr>
        <th class="col-w-title">Stream</th>
        <th class="col-w-title">Video</th>
        <th class="col-w-platform">Platform</th>
        <th>Duration</th>
        <th class="col-w-status">Status</th>
        <th class="col-w-date">Stopped</th>
        <th class="col-w-actions"></th>
      </tr></thead>
      <tbody>
        <% history.forEach(h => { %>
          <tr>
            <td class="truncate" title="<%= h.stream_name %>"><%= h.stream_name %></td>
            <td class="truncate" title="<%= h.video_title || '-' %>"><%= h.video_title || '-' %></td>
            <td><%= h.platform %></td>
            <td class="small muted"><%
              const dur = h.duration_seconds || 0;
              const hh = Math.floor(dur / 3600);
              const mm = Math.floor((dur % 3600) / 60);
              const ss = dur % 60;
              if (hh > 0) { %><%= hh %>h <%= mm %>m<%
              } else if (mm > 0) { %><%= mm %>m <%= ss %>s<%
              } else { %><%= ss %>s<% } %>
            </td>
            <td>
              <span class="badge badge-<%= h.status === 'completed' ? 'idle' : 'error' %>"><%= h.status %></span>
            </td>
            <td class="col-date small muted"><%= formatTime(h.stopped_at) %></td>
            <td class="col-actions">
              <form method="POST" action="/history/<%= h.id %>/delete"
                    data-confirm="Hapus entry ini dari riwayat?"
                    data-confirm-title="Delete"
                    data-confirm-action="Hapus">
                <button type="submit" class="btn btn-sm btn-icon" title="Delete">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                </button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>
<%- include('partials/footer') %>
