<%- include('partials/header', {
  title: 'Videos',
  activeNav: 'videos',
  pageTitle: typeof currentFolder !== 'undefined' && currentFolder ? currentFolder.name : 'Videos',
  pageSubtitle: typeof currentFolder !== 'undefined' && currentFolder ? 'Folder · ' + videos.length + ' video' : 'Upload, prepare, dan kelola library video.',
  topbarActions: `
    <button type="button" class="btn btn-primary" data-open-modal="upload">+ Upload video</button>
  `,
}) %>
<%- include('partials/flash', { error, notice }) %>

<div class="folder-bar">
  <div class="folder-list">
    <a href="/videos" class="folder-chip <%= (typeof currentFolder === 'undefined' || !currentFolder) ? 'active' : '' %>">
      All (<%= videos.length %>)
    </a>
    <% if (typeof folders !== 'undefined' && folders) { folders.forEach(f => { %>
      <a href="/videos?folder=<%= f.id %>" class="folder-chip <%= (typeof currentFolder !== 'undefined' && currentFolder && currentFolder.id === f.id) ? 'active' : '' %>">
        📁 <%= f.name %> (<%= f.video_count %>)
      </a>
    <% }); } %>
    <button type="button" class="folder-chip folder-chip-add" data-open-modal="new-folder">+ Folder</button>
  </div>
  <% if (typeof currentFolder !== 'undefined' && currentFolder) { %>
    <div class="folder-actions">
      <% const uploadedCount = videos.filter(v => v.status === 'uploaded').length; %>
      <% const readyCount = videos.filter(v => v.status === 'ready').length; %>
      <% if (readyCount > 0) { %>
        <form method="POST" action="/videos/folders/<%= currentFolder.id %>/create-playlist" class="inline"
              data-confirm="Buat playlist baru '<%= currentFolder.name %>' dari <%= readyCount %> video ready di folder ini?"
              data-confirm-title="Create playlist"
              data-confirm-action="Buat">
          <button type="submit" class="btn btn-sm btn-primary" title="Create playlist from this folder">▶ Create playlist</button>
        </form>
      <% } %>
      <% if (uploadedCount > 0) { %>
        <button type="button" class="btn btn-sm" data-open-modal="bulk-prepare" title="Prepare all uploaded videos in this folder">⚙ Prepare all (<%= uploadedCount %>)</button>
      <% } %>
      <button type="button" class="btn btn-sm" data-open-modal="rename-folder">Rename</button>
      <form method="POST" action="/videos/folders/<%= currentFolder.id %>/delete" class="inline"
            data-confirm="Hapus folder '<%= currentFolder.name %>'? Video di dalamnya tidak akan dihapus, hanya dipindah ke unfiled."
            data-confirm-title="Hapus folder"
            data-confirm-action="Hapus">
        <button type="submit" class="btn btn-sm btn-danger">Delete folder</button>
      </form>
    </div>
  <% } %>
</div>

<% if (videos.length === 0) { %>
  <div class="card empty">
    <p class="muted">Belum ada video.</p>
    <button type="button" class="btn btn-primary" data-open-modal="upload">+ Upload pertama</button>
  </div>
<% } else { %>
  <div class="table-wrap card card-flush">
    <table class="table videos-table">
      <thead><tr>
        <th class="col-w-thumb"></th>
        <th class="col-w-title">Title</th>
        <th class="col-w-status">Status</th>
        <th class="col-w-actions">Actions</th>
      </tr></thead>
      <tbody>
        <% videos.forEach(v => { %>
          <tr>
            <td class="col-thumb">
              <% if (v.thumbnail) { %>
                <button type="button" class="video-thumb-btn"
                        data-open-modal="video-preview"
                        data-video-id="<%= v.id %>"
                        data-video-src="/videos/<%= v.id %>/file"
                        data-video-title="<%= v.title %>"
                        data-video-info="<%= v.src_width && v.src_height ? v.src_width + '×' + v.src_height : '' %><%= v.size_bytes ? ' · ' + (v.size_bytes / (1024*1024)).toFixed(1) + ' MB' : '' %><%= v.duration_seconds ? ' · ' + Math.floor(v.duration_seconds/60) + 'm ' + Math.floor(v.duration_seconds%60) + 's' : '' %>"
                        title="Preview video">
                  <img src="/videos/<%= v.id %>/thumb" alt="" class="video-thumb" loading="lazy">
                  <span class="video-thumb-play">▶</span>
                </button>
              <% } else { %>
                <form method="POST" action="/videos/<%= v.id %>/regen-thumb" class="inline" title="Generate thumbnail">
                  <button type="submit" class="video-thumb video-thumb-empty">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="14" height="14" rx="2"/><path d="M22 7l-6 5 6 5V7z"/></svg>
                  </button>
                </form>
              <% } %>
            </td>
            <td class="video-title-cell">
              <div class="video-title" title="<%= v.title %>"><%= v.title %></div>
              <div class="video-meta small muted">
                <%= (v.size_bytes / (1024*1024)).toFixed(1) %> MB
                · <%= formatTime(v.created_at) %>
                <% if (v.duration_seconds) { %>
                  <% const dur = Math.round(v.duration_seconds); %>
                  <% const h = Math.floor(dur / 3600); %>
                  <% const m = Math.floor((dur % 3600) / 60); %>
                  <% const s = dur % 60; %>
                  · <%= h > 0 ? h + 'h ' + m + 'm' : m + 'm ' + s + 's' %>
                <% } %>
                <% if (v.src_width && v.src_height) { %>
                  · <%= v.src_width %>×<%= v.src_height %>
                <% } %>
              </div>
            </td>
            <td>
              <% if (v.status === 'ready') { %>
                <span class="badge badge-running">ready</span>
              <% } else if (v.status === 'downloading') { %>
                <span class="badge badge-idle">downloading…</span>
              <% } else if (v.status === 'transcoding') { %>
                <button type="button"
                        class="badge badge-idle badge-btn"
                        data-open-modal="job-detail"
                        data-video-id="<%= v.id %>"
                        data-video-title="<%= v.title %>"
                        title="Klik untuk detail">
                  transcoding <span data-progress-badge-pct="<%= v.id %>">…</span>
                </button>
              <% } else if (v.status === 'error') { %>
                <button type="button"
                        class="badge badge-error badge-btn"
                        data-open-modal="job-detail"
                        data-video-id="<%= v.id %>"
                        data-video-title="<%= v.title %>"
                        title="Lihat log error">
                  error
                </button>
              <% } else { %>
                <span class="badge badge-idle"><%= v.status %></span>
              <% } %>
              <% if (v._readiness && v.status === 'uploaded') { %>
                <% if (v._readiness.level === 'ready') { %>
                  <span class="badge badge-running" title="<%= v._readiness.reasons.join(' · ') %>">✓ stream-ready</span>
                <% } else if (v._readiness.level === 'ok') { %>
                  <span class="badge badge-warn" title="<%= v._readiness.reasons.join(' · ') %>">⚠ suboptimal</span>
                <% } else if (v._readiness.level === 'needs-prepare') { %>
                  <span class="badge badge-error" title="<%= v._readiness.reasons.join(' · ') %>">✗ needs Prepare</span>
                <% } %>
              <% } %>
            </td>
            <td class="actions">
              <% if (v.status === 'transcoding') { %>
                <button type="button" class="btn btn-link"
                        data-open-modal="job-detail"
                        data-video-id="<%= v.id %>"
                        data-video-title="<%= v.title %>">Details</button>
              <% } else if (v.status === 'ready') { %>
                <button type="button" class="btn-icon"
                        data-open-modal="prepare"
                        data-video-id="<%= v.id %>"
                        data-video-title="<%= v.title %>"
                        data-src-width="<%= v.src_width || '' %>"
                        data-src-height="<%= v.src_height || '' %>"
                        data-src-fps="<%= v.src_fps || '' %>"
                        data-src-bitrate="<%= v.video_bitrate_kbps || '' %>"
                        title="Re-Prepare">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 4v6h6"/><path d="M23 20v-6h-6"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
                </button>
              <% } else { %>
                <button type="button" class="btn btn-primary btn-sm"
                        data-open-modal="prepare"
                        data-video-id="<%= v.id %>"
                        data-video-title="<%= v.title %>"
                        data-src-width="<%= v.src_width || '' %>"
                        data-src-height="<%= v.src_height || '' %>"
                        data-src-fps="<%= v.src_fps || '' %>"
                        data-src-bitrate="<%= v.video_bitrate_kbps || '' %>">
                  <%= v.status === 'error' ? 'Retry Prepare' : 'Prepare' %>
                </button>
              <% } %>
              <button type="button" class="btn-icon"
                      data-open-modal="edit-video"
                      data-video-id="<%= v.id %>"
                      data-video-title="<%= v.title %>"
                      data-folder-id="<%= v.folder_id || '' %>"
                      title="Edit">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </button>
              <a href="/videos/<%= v.id %>/download" class="btn-icon" title="Download" download>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              </a>
              <button type="button" class="btn-icon"
                      data-open-modal="video-detail"
                      data-video-id="<%= v.id %>"
                      data-video-title="<%= v.title %>"
                      title="Detail Video">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
              </button>
              <% if (v.status === 'ready') { %>
                <% if (v.youtube_status === 'uploading' || v.youtube_status === 'pending') { %>
                  <button type="button" class="btn-icon"
                          title="Uploading to YouTube — <%= v.youtube_percent || 0 %>% — klik untuk lihat detail"
                          data-yt-watch-job="<%= v.youtube_job_id %>"
                          data-yt-watch-video="<%= v.id %>"
                          data-yt-resume-job="<%= v.youtube_job_id %>"
                          data-video-title="<%= v.title %>"
                          style="color:var(--accent);">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    <span class="yt-pct" style="font-size:10px;font-weight:600;margin-left:2px;"><%= v.youtube_percent || 0 %>%</span>
                  </button>
                <% } else if (v.youtube_video_id) { %>
                  <a href="https://studio.youtube.com/video/<%= v.youtube_video_id %>/edit"
                     target="_blank" rel="noopener"
                     class="btn-icon" style="color:#22c55e;"
                     title="Uploaded — open in YouTube Studio">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                  </a>
                <% } else if (v.youtube_interrupted && youtubeConnected) { %>
                  <button type="button" class="btn-icon"
                          data-open-modal="upload-youtube"
                          data-video-id="<%= v.id %>"
                          data-video-title="<%= v.title %>"
                          title="Upload was interrupted by server restart — click to retry from start"
                          style="color:#f59e0b;">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                  </button>
                <% } else if (youtubeConnected) { %>
                  <button type="button" class="btn-icon"
                          data-open-modal="upload-youtube"
                          data-video-id="<%= v.id %>"
                          data-video-title="<%= v.title %>"
                          title="Upload to YouTube">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                  </button>
                <% } else { %>
                  <a href="/youtube" class="btn-icon" title="Connect YouTube to enable upload" style="opacity:0.5;">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                  </a>
                <% } %>
              <% } %>
              <form method="POST" action="/videos/<%= v.id %>/delete" class="inline"
                    data-confirm="Hapus video '<%= v.title %>'? File di disk akan ikut terhapus."
                    data-confirm-title="Hapus video"
                    data-confirm-action="Hapus">
                <button class="btn-icon btn-icon-danger" type="submit" title="Delete">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                </button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% if (typeof totalPages !== 'undefined' && totalPages > 1) {
       const baseUrl = '/videos?' + (typeof currentFolder !== 'undefined' && currentFolder ? 'folder=' + currentFolder.id + '&' : '');
       const pageUrl = (n) => baseUrl + 'page=' + n;
       // Build page numbers with ellipsis: 1 ... 4 5 [6] 7 8 ... 20
       const windowSize = 2;
       const pages = [];
       for (let i = 1; i <= totalPages; i++) {
         if (i === 1 || i === totalPages || (i >= page - windowSize && i <= page + windowSize)) {
           pages.push(i);
         } else if (pages[pages.length - 1] !== '...') {
           pages.push('...');
         }
       }
  %>
    <div class="pagination">
      <span class="small muted">Showing <%= (page - 1) * perPage + 1 %>–<%= Math.min(page * perPage, totalCount) %> of <%= totalCount %></span>
      <div class="pagination-buttons">
        <% if (page > 1) { %>
          <a href="<%= pageUrl(page - 1) %>" class="btn btn-sm">← Prev</a>
        <% } else { %>
          <span class="btn btn-sm btn-disabled">← Prev</span>
        <% } %>
        <% pages.forEach(p => { %>
          <% if (p === '...') { %>
            <span class="page-ellipsis">…</span>
          <% } else if (p === page) { %>
            <span class="btn btn-sm btn-primary btn-disabled"><%= p %></span>
          <% } else { %>
            <a href="<%= pageUrl(p) %>" class="btn btn-sm"><%= p %></a>
          <% } %>
        <% }); %>
        <% if (page < totalPages) { %>
          <a href="<%= pageUrl(page + 1) %>" class="btn btn-sm">Next →</a>
        <% } else { %>
          <span class="btn btn-sm btn-disabled">Next →</span>
        <% } %>
      </div>
    </div>
  <% } %>
<% } %>

<dialog id="upload" class="modal">
  <div class="modal-card">
    <header class="modal-header">
      <h2>Add video</h2>
      <button type="button" class="modal-close" data-close-modal aria-label="Close">×</button>
    </header>
    <div class="modal-tabs">
      <button type="button" class="tab active" data-tab="tab-upload">From PC</button>
      <button type="button" class="tab" data-tab="tab-url">From URL</button>
    </div>
    <div id="tab-upload" class="tab-panel active">
      <form method="POST" action="/videos/upload" enctype="multipart/form-data" id="upload-form">
        <div class="modal-body">
          <label>Title <input name="title" placeholder="(optional, pakai nama file kalau kosong)"></label>
          <label>File <input type="file" name="video" accept="video/*" required></label>
          <% if (typeof currentFolder !== 'undefined' && currentFolder) { %>
            <input type="hidden" name="folder_id" value="<%= currentFolder.id %>">
            <p class="muted small">Upload ke folder: <strong><%= currentFolder.name %></strong></p>
          <% } else if (typeof folders !== 'undefined' && folders.length > 0) { %>
            <label>Folder (optional)
              <select name="folder_id">
                <option value="">(No folder)</option>
                <% folders.forEach(f => { %>
                  <option value="<%= f.id %>"><%= f.name %></option>
                <% }) %>
              </select>
            </label>
          <% } %>
          <p class="muted small">
            Allowed formats: mp4, mkv, mov, flv, ts, webm. Max 5 GB.
          </p>
          <div id="resume-banner" class="resume-banner" style="display:none">
            <div class="resume-banner-text">
              <strong>Resume upload?</strong>
              <span class="small muted" id="resume-banner-info"></span>
            </div>
            <div class="resume-banner-actions">
              <button type="button" class="btn btn-sm btn-primary" id="resume-banner-resume">Resume</button>
              <button type="button" class="btn btn-sm" id="resume-banner-discard">Discard</button>
            </div>
          </div>
          <div id="upload-progress" class="progress" style="display:none">
            <div class="progress-bar" style="width:0%"></div>
            <div class="progress-label small">starting…</div>
          </div>
        </div>
        <footer class="modal-footer">
          <button type="button" class="btn" data-close-modal id="upload-cancel">Batal</button>
          <button type="submit" class="btn btn-primary" id="upload-submit">Upload</button>
        </footer>
      </form>
    </div>
    <div id="tab-url" class="tab-panel">
      <form method="POST" action="/videos/import-url" id="import-form">
        <div class="modal-body">
          <label>URL
            <input name="url" type="url" required placeholder="https://drive.google.com/file/d/... atau link lain">
          </label>
          <label>Title <input name="title" placeholder="(optional, auto-detect dari source)"></label>
          <p class="muted small">
            Supported: Google Drive, Mega, MediaFire, atau direct link ke file video.
          </p>
        </div>
        <footer class="modal-footer">
          <button type="button" class="btn" data-close-modal>Batal</button>
          <button type="submit" class="btn btn-primary">Download</button>
        </footer>
      </form>
    </div>
  </div>
</dialog>

<dialog id="prepare" class="modal">
  <div class="modal-card">
    <header class="modal-header">
      <h2>Prepare video</h2>
      <button type="button" class="modal-close" data-close-modal aria-label="Close">×</button>
    </header>
    <form method="POST" id="prepare-form">
      <div class="modal-body">
        <p class="muted small" id="prepare-desc">Transcode <strong id="prepare-title"></strong> jadi stream-ready (H.264 + AAC, GOP 2 detik). File original akan diganti.</p>
        <div class="src-info" id="prepare-src-info" style="display:none">
          <span class="badge badge-idle" id="prepare-src-badge"></span>
          <span class="small muted" id="prepare-src-note"></span>
        </div>
        <div class="grid-2">
          <label>Resolution / FPS
            <select name="preset">
              <% Object.keys(presets).forEach(p => { const isLow = /-low$/.test(p); %>
                <option value="<%= p %>" <%= p === '1080p30' ? 'selected' : '' %>><%= p %> · <%= presets[p].br %><%= isLow ? ' (hemat bandwidth)' : '' %></option>
              <% }) %>
            </select>
          </label>
          <label>x264 preset
            <select name="x264_preset" title="Trade-off antara kecepatan encode dan ukuran file">
              <option value="ultrafast">ultrafast</option>
              <option value="superfast">superfast</option>
              <option value="veryfast">veryfast</option>
              <option value="faster">faster</option>
              <option value="fast">fast</option>
              <option value="medium" selected>medium (recommended)</option>
              <option value="slow">slow</option>
            </select>
          </label>
        </div>
      </div>
      <footer class="modal-footer">
        <button type="button" class="btn" data-close-modal>Batal</button>
        <button type="submit" class="btn btn-primary">Mulai Prepare</button>
      </footer>
    </form>
  </div>
</dialog>

<dialog id="job-detail" class="modal modal-lg">
  <div class="modal-card">
    <header class="modal-header">
      <h2 id="job-title">Transcode detail</h2>
      <button type="button" class="modal-close" data-close-modal aria-label="Close">×</button>
    </header>
    <div class="modal-body">
      <div class="job-status">
        <span class="badge" id="job-badge">loading</span>
        <span class="small muted" id="job-eta"></span>
      </div>
      <div class="progress progress-lg">
        <div class="progress-bar" id="job-bar" style="width:0%"></div>
        <div class="progress-label" id="job-label">starting…</div>
      </div>
      <div class="job-stats" id="job-stats">
        <span><span class="muted">time</span> <span id="job-time">-</span></span>
        <span><span class="muted">speed</span> <span id="job-speed">-</span></span>
        <span><span class="muted">fps</span> <span id="job-fps">-</span></span>
        <span><span class="muted">eta</span> <span id="job-eta2">-</span></span>
      </div>
      <h3 class="log-heading">FFmpeg log <span class="small muted">(last 60 lines)</span></h3>
      <pre class="log-box" id="job-log">(belum ada log)</pre>
    </div>
    <footer class="modal-footer">
      <form method="POST" id="job-cancel-form" class="inline" style="display:none">
        <button class="btn btn-warn" type="submit">Cancel transcode</button>
      </form>
      <form method="POST" id="job-retry-form" class="inline" style="display:none"
            data-confirm="Mulai Prepare ulang? File sumber akan ditimpa."
            data-confirm-title="Retry Prepare"
            data-confirm-action="Retry">
        <input type="hidden" name="preset" value="1080p30">
        <input type="hidden" name="x264_preset" value="medium">
        <button class="btn btn-primary" type="submit">Retry Prepare</button>
      </form>
      <button type="button" class="btn" data-close-modal>Close</button>
    </footer>
  </div>
</dialog>

<script>
// Fill Prepare form target before opening.
document.addEventListener('modal:before-open', (e) => {
  if (e.detail.id !== 'prepare') return;
  const btn = e.detail.trigger;
  if (!btn) return;
  const id = btn.dataset.videoId;
  const title = btn.dataset.videoTitle || '';
  const isReprepare = btn.textContent.trim().toLowerCase().startsWith('re');
  document.getElementById('prepare-form').action = '/videos/' + id + '/prepare';
  document.getElementById('prepare-title').textContent = title;
  document.getElementById('prepare-desc').innerHTML = isReprepare
    ? 'Re-encode <strong>' + title + '</strong> ke preset baru. File yang sudah ready sekarang akan <strong>ditimpa</strong>. Stream yang lagi running akan error.'
    : 'Transcode <strong>' + title + '</strong> jadi stream-ready (H.264 + AAC, GOP 2 detik). File original akan diganti.';

  // Auto-select best matching preset based on source resolution/fps.
  const w = Number(btn.dataset.srcWidth) || 0;
  const h = Number(btn.dataset.srcHeight) || 0;
  const fps = Number(btn.dataset.srcFps) || 0;
  const bitrate = Number(btn.dataset.srcBitrate) || 0;
  const srcInfo = document.getElementById('prepare-src-info');
  const srcBadge = document.getElementById('prepare-src-badge');
  const srcNote = document.getElementById('prepare-src-note');
  const presetSel = document.querySelector('#prepare-form select[name="preset"]');

  if (w && h) {
    let badgeText = w + '×' + h + (fps ? ' @ ' + Math.round(fps) + 'fps' : '');
    if (bitrate) badgeText += ' · ' + bitrate + ' kbps';
    srcBadge.textContent = badgeText;
    srcInfo.style.display = 'flex';

    // Pick the best matching preset: same or lower resolution, same or lower fps.
    // Priority: exact match > lower res > lowest available.
    // We auto-pick high-quality variants only; -low presets remain available
    // in the dropdown for users with bandwidth constraints.
    const PRESETS = [
      { key: '1080p60', w: 1920, h: 1080, fps: 60 },
      { key: '1080p30', w: 1920, h: 1080, fps: 30 },
      { key: '720p60',  w: 1280, h: 720,  fps: 60 },
      { key: '720p30',  w: 1280, h: 720,  fps: 30 },
    ];
    // Find best: largest preset that is <= source dimensions.
    let best = null;
    for (const p of PRESETS) {
      if (p.w <= w && p.h <= h) {
        // Prefer fps match; if source fps is close to preset fps, prefer it.
        if (!best) { best = p; continue; }
        const fpsDiff = Math.abs(p.fps - fps);
        const bestFpsDiff = Math.abs(best.fps - fps);
        if (fpsDiff < bestFpsDiff) best = p;
        else if (fpsDiff === bestFpsDiff && p.w > best.w) best = p;
      }
    }
    if (!best) best = PRESETS[PRESETS.length - 1]; // fallback to lowest

    if (presetSel) {
      presetSel.value = best.key;
    }

    // Update note based on currently selected preset (called on open + on change).
    // Strip "-low" suffix when matching; both variants share resolution/fps.
    function updateNote() {
      const baseKey = (presetSel.value || '').replace(/-low$/, '');
      const selected = PRESETS.find(p => p.key === baseKey);
      if (!selected) { srcNote.textContent = ''; return; }
      const isLow = /-low$/.test(presetSel.value);
      const isExact = selected.w === w && selected.h === h;
      const isFpsMatch = fps && Math.abs(selected.fps - fps) < 2;
      let msg, color;
      if (isExact && isFpsMatch) {
        msg = '✓ Preset cocok dengan source';
        color = 'var(--ok)';
      } else if (selected.w > w || selected.h > h) {
        msg = '⚠ Upscale dari source — tidak disarankan';
        color = 'var(--warn)';
      } else if (isExact && selected.fps > fps) {
        msg = '⚠ Source ' + Math.round(fps) + 'fps → ' + selected.fps + 'fps (frame duplikat, tidak tambah kualitas)';
        color = 'var(--warn)';
      } else if (isExact && selected.fps < fps) {
        msg = 'Source ' + Math.round(fps) + 'fps → ' + selected.fps + 'fps (frame di-drop)';
        color = 'var(--muted)';
      } else {
        msg = 'Downscale ke ' + selected.key + ' dari source ' + w + '×' + h;
        color = 'var(--muted)';
      }
      // Append low-bitrate caveat if applicable.
      if (isLow) {
        msg += ' · ⚠ low bitrate (YouTube Studio akan kasih warning)';
        color = 'var(--warn)';
      }
      srcNote.textContent = msg;
      srcNote.style.color = color;
    }

    updateNote();
    // Remove old listener if modal was opened before, then re-attach.
    presetSel.removeEventListener('change', presetSel._noteListener);
    presetSel._noteListener = updateNote;
    presetSel.addEventListener('change', updateNote);
  } else {
    srcInfo.style.display = 'none';
  }
});

// Upload — chunked with auto-resume and retry per chunk.
// Falls back to single XHR for files <= 50 MB (overhead not worth it).
(function () {
  // Tab switching for upload modal.
  const tabs = document.querySelectorAll('.modal-tabs .tab');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      tab.closest('.modal-card').querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      tab.closest('.modal-tabs').querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const panel = document.getElementById(target);
      if (panel) panel.classList.add('active');
    });
  });

  const form = document.getElementById('upload-form');
  if (!form) return;
  const dlg = document.getElementById('upload');
  const progress = document.getElementById('upload-progress');
  const bar = progress.querySelector('.progress-bar');
  const label = progress.querySelector('.progress-label');
  const submitBtn = document.getElementById('upload-submit');
  const cancelBtn = document.getElementById('upload-cancel');

  // Tunables — kept in sync with src/chunkUpload.js (CHUNK_SIZE = 10 MB).
  const CHUNK_SIZE = 10 * 1024 * 1024;
  const CHUNKED_THRESHOLD = 50 * 1024 * 1024;   // <= 50 MB: simple XHR
  const MAX_RETRIES_PER_CHUNK = 5;
  const RETRY_BASE_DELAY = 2000;                 // 2s, doubles each attempt
  const LS_KEY = 'awanstream:pending_upload';   // localStorage key for resume

  // -------- Resume state (localStorage) --------
  function lsGet() {
    try {
      const raw = localStorage.getItem(LS_KEY);
      if (!raw) return null;
      const v = JSON.parse(raw);
      if (!v || !v.uploadId) return null;
      return v;
    } catch (_) { return null; }
  }
  function lsSet(v) {
    try { localStorage.setItem(LS_KEY, JSON.stringify(v)); } catch (_) {}
  }
  function lsClear() {
    try { localStorage.removeItem(LS_KEY); } catch (_) {}
  }
  // File identity check — same name, size, lastModified means very likely
  // the same file. Not 100% guaranteed (could rename + edit), but good enough
  // and avoids hashing 400 MB on every modal open.
  function fileMatches(savedFile, file) {
    if (!savedFile || !file) return false;
    return savedFile.name === file.name
      && savedFile.size === file.size
      && savedFile.lastModified === file.lastModified;
  }

  function fmtBytes(n) {
    if (n < 1024) return n + ' B';
    if (n < 1024 * 1024) return (n / 1024).toFixed(1) + ' KB';
    if (n < 1024 * 1024 * 1024) return (n / 1024 / 1024).toFixed(1) + ' MB';
    return (n / 1024 / 1024 / 1024).toFixed(2) + ' GB';
  }
  function fmtEta(sec) {
    if (!Number.isFinite(sec) || sec < 0) return '—';
    const m = Math.floor(sec / 60), s = Math.floor(sec % 60);
    if (m >= 60) {
      const h = Math.floor(m / 60), mm = m % 60;
      return h + 'h ' + mm + 'm';
    }
    return m + 'm ' + s + 's';
  }
  function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

  let activeXhr = null;
  let cancelled = false;

  // Resume banner state — populated when modal opens with a pending upload.
  let pendingResume = null;     // { uploadId, totalChunks, receivedChunks[], filename, fileSize, title, folderId }
  const resumeBanner = document.getElementById('resume-banner');
  const resumeBannerInfo = document.getElementById('resume-banner-info');
  const resumeBtn = document.getElementById('resume-banner-resume');
  const discardBtn = document.getElementById('resume-banner-discard');

  function hideResumeBanner() {
    if (resumeBanner) resumeBanner.style.display = 'none';
    pendingResume = null;
  }

  async function checkPendingUpload() {
    hideResumeBanner();
    const saved = lsGet();
    if (!saved || !saved.uploadId) return;
    // Ask server if session still exists & is incomplete.
    let info;
    try {
      const r = await fetch('/videos/chunked/' + encodeURIComponent(saved.uploadId) + '/status');
      if (!r.ok) { lsClear(); return; }
      info = await r.json();
    } catch (_) { return; }
    if (!info || info.complete) { lsClear(); return; }
    pendingResume = {
      uploadId: info.uploadId,
      filename: info.filename,
      fileSize: info.fileSize,
      totalChunks: info.totalChunks,
      receivedChunks: info.receivedChunks || [],
      savedFile: saved.file || null,
      title: saved.title || '',
      folderId: saved.folderId || '',
    };
    const pct = Math.round((pendingResume.receivedChunks.length / pendingResume.totalChunks) * 100);
    if (resumeBannerInfo) {
      resumeBannerInfo.textContent = pendingResume.filename
        + ' · ' + fmtBytes(pendingResume.fileSize)
        + ' · ' + pct + '% done (' + pendingResume.receivedChunks.length + '/' + pendingResume.totalChunks + ' chunks)';
    }
    if (resumeBanner) resumeBanner.style.display = 'flex';
  }

  if (discardBtn) {
    discardBtn.addEventListener('click', async () => {
      if (!pendingResume) { hideResumeBanner(); return; }
      try {
        await fetch('/videos/chunked/' + encodeURIComponent(pendingResume.uploadId), { method: 'DELETE' });
      } catch (_) {}
      lsClear();
      hideResumeBanner();
    });
  }

  if (resumeBtn) {
    resumeBtn.addEventListener('click', () => {
      if (!pendingResume) return;
      // User must re-select the same file (browsers don't keep file handles across reloads).
      const fileInput = form.querySelector('input[type=file]');
      fileInput.click();
      // Once user picks a file, the change handler below will validate it
      // matches and trigger the resumed upload automatically.
      fileInput.dataset.pendingResume = '1';
    });
  }

  // When user picks a file with a pending resume, validate match.
  const fileInputForResume = form.querySelector('input[type=file]');
  if (fileInputForResume) {
    fileInputForResume.addEventListener('change', () => {
      if (!fileInputForResume.dataset.pendingResume || !pendingResume) return;
      delete fileInputForResume.dataset.pendingResume;
      const f = fileInputForResume.files && fileInputForResume.files[0];
      if (!f) return;
      if (!fileMatches(pendingResume.savedFile, f)) {
        if (!confirm('File yang dipilih beda dengan upload sebelumnya (nama/ukuran/tanggal modifikasi).\n\nLanjut sebagai upload baru? (Upload lama akan di-discard)')) {
          fileInputForResume.value = '';
          return;
        }
        // Discard old session, treat as fresh upload.
        fetch('/videos/chunked/' + encodeURIComponent(pendingResume.uploadId), { method: 'DELETE' }).catch(() => {});
        lsClear();
        hideResumeBanner();
        return;
      }
      // File matches — auto-submit to trigger resumed upload.
      hideResumeBanner();
      // Defer submit so the change event finishes first.
      setTimeout(() => form.requestSubmit(), 0);
    });
  }

  // ---- Single-XHR fallback (for small files) ----
  function uploadSimple(file, title, folderId) {
    return new Promise((resolve, reject) => {
      const data = new FormData();
      data.append('video', file);
      if (title) data.append('title', title);
      if (folderId) data.append('folder_id', folderId);

      const xhr = new XMLHttpRequest();
      activeXhr = xhr;
      xhr.open('POST', '/videos/upload');

      const started = Date.now();
      xhr.upload.onprogress = (ev) => {
        if (!ev.lengthComputable) return;
        const pct = Math.min(100, Math.round((ev.loaded / ev.total) * 100));
        bar.style.width = pct + '%';
        const elapsed = (Date.now() - started) / 1000;
        const speed = ev.loaded / Math.max(1, elapsed);
        const eta = speed > 0 ? (ev.total - ev.loaded) / speed : null;
        label.textContent = [
          pct + '%',
          fmtBytes(ev.loaded) + ' / ' + fmtBytes(ev.total),
          fmtBytes(speed) + '/s',
          'eta ' + fmtEta(eta),
        ].join(' · ');
      };
      xhr.onload = () => {
        activeXhr = null;
        if (xhr.status >= 200 && xhr.status < 400) resolve();
        else reject(new Error('HTTP ' + xhr.status));
      };
      xhr.onerror = () => { activeXhr = null; reject(new Error('Network error')); };
      xhr.onabort = () => { activeXhr = null; reject(new Error('aborted')); };
      xhr.send(data);
    });
  }

  // ---- Chunked upload with per-chunk retry ----
  // If `existing` is provided ({uploadId, totalChunks, receivedSet}), we skip
  // init and resume from where we left off.
  async function uploadChunked(file, title, folderId, existing) {
    let uploadId, totalChunks;
    let receivedSet = new Set();

    if (existing) {
      uploadId = existing.uploadId;
      totalChunks = existing.totalChunks;
      receivedSet = existing.receivedSet || new Set();
      label.textContent = 'resuming (' + receivedSet.size + '/' + totalChunks + ' chunks done)…';
    } else {
      label.textContent = 'preparing chunks…';
      const initRes = await fetch('/videos/chunked/init', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ filename: file.name, fileSize: file.size }),
      });
      if (!initRes.ok) {
        const err = await initRes.json().catch(() => ({ error: 'HTTP ' + initRes.status }));
        throw new Error(err.error || 'init failed');
      }
      const init = await initRes.json();
      uploadId = init.uploadId;
      totalChunks = init.totalChunks;
      // Persist for resume.
      lsSet({
        uploadId, totalChunks,
        title: title || '',
        folderId: folderId || '',
        file: { name: file.name, size: file.size, lastModified: file.lastModified },
        startedAt: Date.now(),
      });
    }

    // Start counters reflect already-uploaded chunks (resume).
    let bytesUploaded = receivedSet.size * CHUNK_SIZE;
    if (bytesUploaded > file.size) bytesUploaded = file.size; // last chunk smaller
    const startedAt = Date.now();
    let lastSpeedSampleTs = startedAt;
    let lastSpeedSampleBytes = bytesUploaded;
    let smoothedSpeed = 0;

    for (let i = 0; i < totalChunks; i++) {
      if (cancelled) throw new Error('aborted');
      if (receivedSet.has(i)) continue; // already on server

      const start = i * CHUNK_SIZE;
      const end = Math.min(start + CHUNK_SIZE, file.size);
      const blob = file.slice(start, end);

      let attempt = 0;
      while (true) {
        if (cancelled) throw new Error('aborted');
        try {
          await sendChunk(uploadId, i, blob, (chunkLoaded) => {
            const totalLoaded = bytesUploaded + chunkLoaded;
            const pct = Math.min(99, Math.round((totalLoaded / file.size) * 100));
            bar.style.width = pct + '%';
            const now = Date.now();
            const dt = (now - lastSpeedSampleTs) / 1000;
            if (dt >= 1) {
              const inst = (totalLoaded - lastSpeedSampleBytes) / dt;
              smoothedSpeed = smoothedSpeed === 0 ? inst : smoothedSpeed * 0.7 + inst * 0.3;
              lastSpeedSampleTs = now;
              lastSpeedSampleBytes = totalLoaded;
            }
            const eta = smoothedSpeed > 0 ? (file.size - totalLoaded) / smoothedSpeed : null;
            label.textContent = [
              pct + '%',
              fmtBytes(totalLoaded) + ' / ' + fmtBytes(file.size),
              (smoothedSpeed > 0 ? fmtBytes(smoothedSpeed) + '/s' : '…'),
              'eta ' + fmtEta(eta),
              'chunk ' + (i + 1) + '/' + totalChunks + (attempt > 0 ? ' (retry ' + attempt + ')' : ''),
            ].join(' · ');
          });
          break; // success
        } catch (err) {
          if (cancelled) throw new Error('aborted');
          attempt++;
          if (attempt > MAX_RETRIES_PER_CHUNK) {
            throw new Error('Chunk ' + (i + 1) + ' failed after ' + MAX_RETRIES_PER_CHUNK + ' retries: ' + err.message);
          }
          const delay = Math.min(30000, RETRY_BASE_DELAY * Math.pow(2, attempt - 1));
          label.textContent = 'chunk ' + (i + 1) + '/' + totalChunks + ' failed (' + err.message + '), retry in ' + Math.round(delay / 1000) + 's…';
          await sleep(delay);
        }
      }
      bytesUploaded += blob.size;
      receivedSet.add(i);
    }

    // 3. Finalize: server merges chunks, creates video row.
    if (cancelled) throw new Error('aborted');
    label.textContent = 'finalizing…';
    bar.style.width = '99%';
    const finRes = await fetch('/videos/chunked/' + uploadId + '/finalize', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title: title || '', folder_id: folderId || null }),
    });
    if (!finRes.ok) {
      const err = await finRes.json().catch(() => ({ error: 'HTTP ' + finRes.status }));
      throw new Error(err.error || 'finalize failed');
    }
    bar.style.width = '100%';
    lsClear();
    return uploadId;
  }

  // Send a single chunk via XHR so we get upload progress events.
  function sendChunk(uploadId, index, blob, onProgress) {
    return new Promise((resolve, reject) => {
      const xhr = new XMLHttpRequest();
      activeXhr = xhr;
      xhr.open('PUT', '/videos/chunked/' + uploadId + '/' + index);
      xhr.upload.onprogress = (ev) => {
        if (ev.lengthComputable && onProgress) onProgress(ev.loaded);
      };
      xhr.onload = () => {
        activeXhr = null;
        if (xhr.status >= 200 && xhr.status < 400) {
          resolve();
        } else {
          let msg = 'HTTP ' + xhr.status;
          try {
            const j = JSON.parse(xhr.responseText);
            if (j && j.error) msg = j.error;
          } catch (_) {}
          reject(new Error(msg));
        }
      };
      xhr.onerror = () => { activeXhr = null; reject(new Error('network error')); };
      xhr.onabort = () => { activeXhr = null; reject(new Error('aborted')); };
      xhr.ontimeout = () => { activeXhr = null; reject(new Error('timeout')); };
      // No xhr.timeout — chunk size keeps requests bounded; rely on retry on stall.
      xhr.send(blob);
    });
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fileInput = form.querySelector('input[type=file]');
    if (!fileInput.files || fileInput.files.length === 0) return;

    const file = fileInput.files[0];
    const title = form.querySelector('input[name="title"]').value.trim();
    const folderField = form.querySelector('[name="folder_id"]');
    const folderId = folderField ? folderField.value : '';

    cancelled = false;
    progress.style.display = 'block';
    bar.style.width = '0%';
    label.textContent = 'starting…';
    submitBtn.disabled = true;
    submitBtn.textContent = 'Uploading…';
    cancelBtn.textContent = 'Batalkan upload';

    // If a resume is in progress and the picked file matches, resume.
    let existing = null;
    if (pendingResume && fileMatches(pendingResume.savedFile, file)) {
      existing = {
        uploadId: pendingResume.uploadId,
        totalChunks: pendingResume.totalChunks,
        receivedSet: new Set(pendingResume.receivedChunks),
      };
    }

    // Disk pre-check (skip for resume — server already accepted earlier).
    if (!existing) {
      try {
        const r = await fetch('/videos/disk-check?bytes=' + file.size, { cache: 'no-store' });
        if (r.ok) {
          const dc = await r.json();
          if (!dc.ok) {
            const free = dc.stats ? fmtBytes(dc.stats.free) : '?';
            label.textContent = 'disk hampir penuh: free ' + free + ' (' + (dc.reason || 'tidak cukup') + ')';
            submitBtn.disabled = false;
            submitBtn.textContent = 'Upload';
            cancelBtn.textContent = 'Batal';
            return;
          }
        }
      } catch (_) { /* server unreachable — let backend reject if needed */ }
    }

    try {
      if (file.size <= CHUNKED_THRESHOLD && !existing) {
        await uploadSimple(file, title, folderId);
      } else {
        await uploadChunked(file, title, folderId, existing);
      }
      label.textContent = 'done, reloading…';
      try { dlg.close(); } catch (_) {}
      window.location.href = '/videos';
    } catch (err) {
      if (err && err.message === 'aborted') {
        label.textContent = 'upload dibatalkan (chunks kept on server, refresh untuk Resume)';
        bar.style.width = '0%';
      } else {
        label.textContent = 'upload failed: ' + (err && err.message ? err.message : err);
      }
      submitBtn.disabled = false;
      submitBtn.textContent = 'Upload';
      cancelBtn.textContent = 'Batal';
    }
  });

  cancelBtn.addEventListener('click', (e) => {
    if (!submitBtn.disabled) return; // not uploading, default close
    e.preventDefault();
    e.stopPropagation();
    cancelled = true;
    if (activeXhr && activeXhr.readyState !== XMLHttpRequest.DONE) {
      try { activeXhr.abort(); } catch (_) {}
      activeXhr = null;
    }
  }, true);

  dlg.addEventListener('modal:before-open', () => {
    progress.style.display = 'none';
    bar.style.width = '0%';
    label.textContent = 'starting…';
    submitBtn.disabled = false;
    submitBtn.textContent = 'Upload';
    cancelBtn.textContent = 'Batal';
    cancelled = false;
    activeXhr = null;
    form.reset();
    // Check for pending upload to offer resume.
    checkPendingUpload();
  });
})();

// ----- Job detail modal (transcoding progress + log) -----
(function () {
  const dlg = document.getElementById('job-detail');
  if (!dlg) return;

  const titleEl = document.getElementById('job-title');
  const badgeEl = document.getElementById('job-badge');
  const etaEl = document.getElementById('job-eta');
  const barEl = document.getElementById('job-bar');
  const labelEl = document.getElementById('job-label');
  const timeEl = document.getElementById('job-time');
  const speedEl = document.getElementById('job-speed');
  const fpsEl = document.getElementById('job-fps');
  const eta2El = document.getElementById('job-eta2');
  const logEl = document.getElementById('job-log');
  const cancelForm = document.getElementById('job-cancel-form');
  const retryForm = document.getElementById('job-retry-form');

  let currentId = null;
  let pollTimer = null;
  let stickToBottom = true;

  function fmtSec(s) {
    if (s == null || !Number.isFinite(s) || s < 0) return '-';
    const h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60), sec = Math.floor(s % 60);
    return (h ? String(h).padStart(2, '0') + ':' : '') +
      String(m).padStart(2, '0') + ':' + String(sec).padStart(2, '0');
  }

  function render(d) {
    titleEl.textContent = d.title || 'Transcode detail';
    badgeEl.className = 'badge badge-' +
      (d.status === 'transcoding' ? 'idle' :
       d.status === 'ready' ? 'running' :
       d.status === 'error' ? 'error' : 'idle');
    badgeEl.textContent = d.status;

    const pct = d.percent != null ? d.percent : (d.status === 'ready' ? 100 : 0);
    barEl.style.width = pct + '%';

    const parts = [];
    if (d.percent != null) parts.push(pct + '%');
    if (d.time) parts.push(fmtSec(d.time) + (d.duration ? ' / ' + fmtSec(d.duration) : ''));
    if (d.speed) parts.push(d.speed.toFixed(2) + 'x');
    labelEl.textContent = parts.join(' · ') || (d.status === 'ready' ? 'done' : 'working…');

    timeEl.textContent = d.time ? fmtSec(d.time) : '-';
    speedEl.textContent = d.speed ? d.speed.toFixed(2) + 'x' : '-';
    fpsEl.textContent = d.fps ? Math.round(d.fps) + '' : '-';
    eta2El.textContent = fmtSec(d.eta_seconds);
    etaEl.textContent = d.status === 'transcoding' && d.eta_seconds
      ? '~' + fmtSec(d.eta_seconds) + ' left'
      : (d.last_error || '');

    if (d.log_tail != null && d.log_tail !== logEl.textContent) {
      const nearBottom = stickToBottom;
      logEl.textContent = d.log_tail || '(belum ada log)';
      if (nearBottom) logEl.scrollTop = logEl.scrollHeight;
    }

    // Toggle action buttons based on status.
    cancelForm.style.display = d.status === 'transcoding' ? '' : 'none';
    cancelForm.action = '/videos/' + d.id + '/cancel-prepare';
    retryForm.style.display = d.status === 'error' ? '' : 'none';
    retryForm.action = '/videos/' + d.id + '/prepare';
  }

  async function poll() {
    if (!currentId) return;
    try {
      const r = await fetch('/videos/' + currentId + '/status', { cache: 'no-store' });
      if (!r.ok) {
        labelEl.textContent = 'failed to load (' + r.status + ')';
        logEl.textContent = r.status === 404
          ? 'Endpoint belum tersedia. Restart server dulu (Ctrl+C lalu `node app.js`).'
          : 'HTTP ' + r.status + ' ' + r.statusText;
        return;
      }
      const ct = r.headers.get('content-type') || '';
      if (!ct.includes('application/json')) {
        labelEl.textContent = 'session expired';
        logEl.textContent = 'Sesi login habis. Refresh halaman dan login ulang.';
        return;
      }
      const d = await r.json();
      render(d);
      if (d.status !== 'transcoding' && !dlg.dataset.reloadScheduled) {
        dlg.dataset.reloadScheduled = '1';
        setTimeout(() => { if (!dlg.open) window.location.reload(); }, 3000);
      }
    } catch (err) {
      labelEl.textContent = 'network error';
      logEl.textContent = String(err && err.message ? err.message : err);
    }
  }

  // Track whether user scrolled away from the bottom of the log.
  logEl.addEventListener('scroll', () => {
    const delta = logEl.scrollHeight - logEl.scrollTop - logEl.clientHeight;
    stickToBottom = delta < 20;
  });

  document.addEventListener('modal:before-open', (e) => {
    if (e.detail.id !== 'job-detail') return;
    const btn = e.detail.trigger;
    currentId = btn && btn.dataset.videoId ? Number(btn.dataset.videoId) : null;
    titleEl.textContent = (btn && btn.dataset.videoTitle) || 'Transcode detail';
    badgeEl.textContent = 'loading';
    badgeEl.className = 'badge badge-idle';
    labelEl.textContent = 'loading…';
    barEl.style.width = '0%';
    timeEl.textContent = speedEl.textContent = fpsEl.textContent = eta2El.textContent = '-';
    etaEl.textContent = '';
    logEl.textContent = '(loading log…)';
    stickToBottom = true;
    delete dlg.dataset.reloadScheduled;
    poll();
    pollTimer = setInterval(poll, 2000);
  });

  dlg.addEventListener('close', () => {
    if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
    currentId = null;
  });
})();

// Table row status badge — poll percent inline for transcoding rows so the
// badge shows "transcoding 42%" even without opening the modal.
(function () {
  const nodes = document.querySelectorAll('[data-progress-badge-pct]');
  if (nodes.length === 0) return;
  const ids = new Set();
  nodes.forEach((n) => ids.add(n.dataset.progressBadgePct));

  async function pollOne(id) {
    try {
      const r = await fetch('/videos/' + id + '/progress', { cache: 'no-store' });
      if (!r.ok) return;
      const d = await r.json();
      if (d.status !== 'transcoding') { window.location.reload(); return; }
      const pct = d.percent != null ? d.percent : null;
      document.querySelectorAll('[data-progress-badge-pct="' + id + '"]').forEach((el) => {
        el.textContent = pct != null ? pct + '%' : '…';
      });
    } catch (_) {}
  }

  ids.forEach((id) => { pollOne(id); setInterval(() => pollOne(id), 3000); });
})();
</script>
