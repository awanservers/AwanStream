<!-- YouTube Upload Modal -->
<dialog id="upload-youtube" class="modal">
  <div class="modal-card">
    <header class="modal-header">
      <h2>Upload to YouTube</h2>
      <button type="button" class="modal-close" data-close-modal aria-label="Close">×</button>
    </header>
    <form id="upload-youtube-form" method="POST">
      <div class="modal-body">
        <p class="muted small" style="margin-top:0;">
          Video di-upload sebagai <strong>Unlisted</strong> by default — kamu bisa edit metadata (title, description, tags, thumbnail) dan publish manual lewat YouTube Studio setelah selesai.
        </p>
        <p class="muted small" style="margin:0 0 10px; padding:8px 10px; background:rgba(245,158,11,0.1); border-left:3px solid #f59e0b; border-radius:4px;">
          ⚠ <strong>Note:</strong> Kalau server restart saat upload berlangsung, kamu harus mulai ulang dari awal (resume across restart belum di-support). Untuk file besar, pastikan VPS / koneksi stabil.
        </p>
        <div class="grid-2">
          <label class="full">Title
            <input type="text" name="title" id="yt-upload-title" required maxlength="100">
            <span class="small muted">Max 100 karakter. Default pakai title video di Library.</span>
          </label>
          <label class="full">Privacy
            <select name="privacy" id="yt-upload-privacy">
              <option value="unlisted" selected>Unlisted (rekomendasi — bisa diakses via link, tidak muncul di search)</option>
              <option value="private">Private (hanya kamu yang bisa lihat)</option>
              <option value="public">Public (langsung publish — pastikan title & thumbnail sudah final)</option>
            </select>
          </label>
          <label>Category
            <select name="category_id" id="yt-upload-category">
              <option value="10" selected>Music</option>
              <option value="22">People &amp; Blogs</option>
              <option value="24">Entertainment</option>
              <option value="20">Gaming</option>
              <option value="27">Education</option>
              <option value="28">Science &amp; Technology</option>
            </select>
          </label>
        </div>

        <div id="yt-upload-progress" style="display:none; margin-top:18px;">
          <div class="progress"><div class="progress-bar" id="yt-upload-bar" style="width:0%"></div></div>
          <div class="small muted" id="yt-upload-status" style="margin-top:6px;">Starting…</div>
        </div>

        <div id="yt-upload-error" class="alert alert-error" style="display:none; margin-top:14px;"></div>
        <div id="yt-upload-done" class="alert alert-info" style="display:none; margin-top:14px;"></div>
      </div>
      <footer class="modal-footer">
        <button type="button" class="btn" id="yt-upload-cancel-btn" style="display:none;">Cancel upload</button>
        <button type="button" class="btn" data-close-modal id="yt-upload-close-btn">Close</button>
        <button type="submit" class="btn btn-primary" id="yt-upload-submit-btn">Start upload</button>
      </footer>
    </form>
  </div>
</dialog>

<script>
(function() {
  const form = document.getElementById('upload-youtube-form');
  if (!form) return;
  const titleEl = document.getElementById('yt-upload-title');
  const submitBtn = document.getElementById('yt-upload-submit-btn');
  const closeBtn = document.getElementById('yt-upload-close-btn');
  const cancelBtn = document.getElementById('yt-upload-cancel-btn');
  const progressDiv = document.getElementById('yt-upload-progress');
  const progressBar = document.getElementById('yt-upload-bar');
  const statusEl = document.getElementById('yt-upload-status');
  const errEl = document.getElementById('yt-upload-error');
  const doneEl = document.getElementById('yt-upload-done');

  let currentVideoId = null;
  let currentJobId = null;
  let pollTimer = null;
  let resumeMode = false; // true if reopened to track an in-flight upload

  function resetModal() {
    progressDiv.style.display = 'none';
    progressBar.style.width = '0%';
    statusEl.textContent = '';
    errEl.style.display = 'none';
    errEl.textContent = '';
    doneEl.style.display = 'none';
    doneEl.innerHTML = '';
    submitBtn.disabled = false;
    submitBtn.style.display = '';
    cancelBtn.style.display = 'none';
    if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
    resumeMode = false;
  }

  function fmtBytes(b) {
    if (!b) return '0 B';
    if (b < 1024) return b + ' B';
    if (b < 1024*1024) return (b/1024).toFixed(1) + ' KB';
    if (b < 1024*1024*1024) return (b/(1024*1024)).toFixed(1) + ' MB';
    return (b/(1024*1024*1024)).toFixed(2) + ' GB';
  }

  document.addEventListener('modal:before-open', (e) => {
    if (e.detail.id !== 'upload-youtube') return;
    const btn = e.detail.trigger;
    if (!btn) return;
    currentVideoId = btn.dataset.videoId;
    titleEl.value = btn.dataset.videoTitle || '';
    resetModal();
  });

  document.getElementById('upload-youtube').addEventListener('close', () => {
    if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
  });

  async function pollProgress() {
    if (!currentJobId) return;
    try {
      const r = await fetch('/youtube/upload/' + currentJobId + '/progress', { cache: 'no-store' });
      if (!r.ok) {
        if (r.status === 404) {
          // Job expired from memory, assume done — reload to show new state.
          clearInterval(pollTimer); pollTimer = null;
          window.location.reload();
        }
        return;
      }
      const j = await r.json();
      if (!j.ok) return;
      progressBar.style.width = (j.percent || 0) + '%';
      const sent = fmtBytes(j.bytesSent);
      const total = fmtBytes(j.totalBytes);
      statusEl.textContent = (j.status === 'pending' ? 'Preparing…' : 'Uploading') +
        ' — ' + (j.percent || 0) + '% (' + sent + ' / ' + total + ')';

      if (j.status === 'done') {
        clearInterval(pollTimer); pollTimer = null;
        cancelBtn.style.display = 'none';
        doneEl.style.display = 'block';
        const ytId = j.youtubeVideoId;
        doneEl.innerHTML =
          '✓ Upload selesai!<br>' +
          '<a href="https://studio.youtube.com/video/' + ytId + '/edit" target="_blank" rel="noopener" class="btn btn-primary" style="margin-top:8px;">Open in YouTube Studio</a> ' +
          '<a href="https://www.youtube.com/watch?v=' + ytId + '" target="_blank" rel="noopener" class="btn" style="margin-top:8px;">View on YouTube</a>';
        statusEl.textContent = '';
      } else if (j.status === 'error') {
        clearInterval(pollTimer); pollTimer = null;
        cancelBtn.style.display = 'none';
        errEl.style.display = 'block';
        errEl.textContent = '✗ Upload gagal: ' + (j.error || 'unknown error');
        statusEl.textContent = '';
      } else if (j.status === 'cancelled') {
        clearInterval(pollTimer); pollTimer = null;
        cancelBtn.style.display = 'none';
        errEl.style.display = 'block';
        errEl.textContent = 'Upload cancelled.';
        statusEl.textContent = '';
      }
    } catch (e) { /* network blip — keep polling */ }
  }

  form.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    if (resumeMode) return; // don't submit again — already uploading
    if (!currentVideoId) return;
    resetModal();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Starting…';

    const fd = new FormData(form);
    try {
      const r = await fetch('/youtube/upload/' + currentVideoId, {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
        body: fd,
      });
      const j = await r.json();
      submitBtn.textContent = 'Start upload';
      if (!r.ok || !j.ok) {
        errEl.style.display = 'block';
        errEl.textContent = j.error || 'Failed to start upload';
        submitBtn.disabled = false;
        return;
      }
      currentJobId = j.jobId;
      submitBtn.style.display = 'none';
      cancelBtn.style.display = '';
      progressDiv.style.display = 'block';
      statusEl.textContent = 'Uploading — 0%';
      // Start polling.
      pollTimer = setInterval(pollProgress, 2000);
      pollProgress();
    } catch (e) {
      errEl.style.display = 'block';
      errEl.textContent = 'Network error: ' + e.message;
      submitBtn.disabled = false;
      submitBtn.textContent = 'Start upload';
    }
  });

  cancelBtn.addEventListener('click', async () => {
    if (!currentJobId) return;
    if (!confirm('Cancel upload? Progress yang sudah dikirim akan hilang.')) return;
    cancelBtn.disabled = true;
    try {
      await fetch('/youtube/upload/' + currentJobId + '/cancel', {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
      });
    } catch (_) {}
    cancelBtn.disabled = false;
  });

  // Watch active jobs in the table (kalau modal closed tapi job masih running).
  // Update percent badge on YouTube icon every 3s.
  document.querySelectorAll('[data-yt-watch-job]').forEach((el) => {
    const jobId = el.dataset.ytWatchJob;
    if (!jobId) return;

    // Click handler: re-open modal in "resume mode" to show full progress detail.
    el.addEventListener('click', (ev) => {
      ev.preventDefault();
      currentJobId = jobId;
      currentVideoId = el.dataset.ytWatchVideo || null;
      resumeMode = true;
      // Pre-fill UI to "uploading" view immediately.
      resetModal();
      resumeMode = true; // resetModal clears it, set again
      titleEl.value = el.dataset.videoTitle || '(uploading)';
      submitBtn.style.display = 'none';
      cancelBtn.style.display = '';
      progressDiv.style.display = 'block';
      const pct = el.querySelector('.yt-pct');
      if (pct) statusEl.textContent = 'Reconnecting to upload — ' + pct.textContent;
      else statusEl.textContent = 'Reconnecting to upload…';
      // Open modal manually (not via data-open-modal to avoid the modal:before-open
      // event resetting state).
      const dlg = document.getElementById('upload-youtube');
      if (dlg && !dlg.open) dlg.showModal();
      // Start polling immediately.
      pollProgress();
      if (pollTimer) clearInterval(pollTimer);
      pollTimer = setInterval(pollProgress, 2000);
    });

    setInterval(async () => {
      try {
        const r = await fetch('/youtube/upload/' + jobId + '/progress', { cache: 'no-store' });
        if (!r.ok) {
          if (r.status === 404) window.location.reload(); // job done/expired
          return;
        }
        const j = await r.json();
        if (!j.ok) return;
        const pctEl = el.querySelector('.yt-pct');
        if (pctEl) pctEl.textContent = (j.percent || 0) + '%';
        el.title = 'Uploading to YouTube — ' + (j.percent || 0) + '% — klik untuk lihat detail';
        if (j.status === 'done' || j.status === 'error' || j.status === 'cancelled') {
          window.location.reload();
        }
      } catch (_) {}
    }, 3000);
  });
})();
</script>

