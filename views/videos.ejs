<dialog id="video-preview" class="modal modal-lg">
  <div class="modal-card">
    <header class="modal-header">
      <h2 id="preview-title">Preview</h2>
      <button type="button" class="modal-close" data-close-modal aria-label="Close">×</button>
    </header>
    <div class="modal-body" style="padding:0;background:#000;border-radius:0 0 12px 12px">
      <video id="preview-player" controls preload="metadata" style="width:100%;max-height:65vh;display:block">
        Your browser does not support the video tag.
      </video>
      <div id="preview-info" class="small muted" style="padding:0.6rem 1rem;background:var(--panel)"></div>
      <div id="preview-error" class="alert alert-error" style="display:none;margin:1rem">
        Format video ini tidak didukung browser. Jalankan <strong>Prepare</strong> dulu untuk convert ke H.264 MP4.
      </div>
    </div>
    <footer class="modal-footer" style="justify-content:space-between;flex-wrap:wrap;gap:0.5rem">
      <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap">
        <span class="small muted" id="preview-thumb-status"></span>
      </div>
      <div style="display:flex;gap:0.5rem;flex-wrap:wrap">
        <button type="button" class="btn" id="preview-capture-thumb" title="Gunakan frame saat ini sebagai thumbnail">
          📸 Set thumbnail from current frame
        </button>
        <a href="#" class="btn" id="preview-download-thumb" target="_blank" download>
          ⬇ Download thumbnail
        </a>
        <button type="button" class="btn" data-close-modal>Close</button>
      </div>
    </footer>
  </div>
</dialog>
<script>
(function() {
  const dlg = document.getElementById('video-preview');
  if (!dlg) return;
  const player = document.getElementById('preview-player');
  const titleEl = document.getElementById('preview-title');
  const infoEl = document.getElementById('preview-info');
  const errorEl = document.getElementById('preview-error');
  const captureBtn = document.getElementById('preview-capture-thumb');
  const downloadBtn = document.getElementById('preview-download-thumb');
  const statusEl = document.getElementById('preview-thumb-status');
  let currentVideoId = null;

  document.addEventListener('modal:before-open', (e) => {
    if (e.detail.id !== 'video-preview') return;
    const btn = e.detail.trigger;
    if (!btn) return;
    const src = btn.dataset.videoSrc || '';
    currentVideoId = btn.dataset.videoId || null;
    titleEl.textContent = btn.dataset.videoTitle || 'Preview';
    infoEl.textContent = btn.dataset.videoInfo || '';
    errorEl.style.display = 'none';
    player.style.display = 'block';
    player.src = src;
    player.load();
    statusEl.textContent = '';
    if (currentVideoId) {
      downloadBtn.href = '/videos/' + currentVideoId + '/thumb/download';
      downloadBtn.style.display = 'inline-flex';
      captureBtn.style.display = 'inline-flex';
    } else {
      downloadBtn.style.display = 'none';
      captureBtn.style.display = 'none';
    }
  });

  player.addEventListener('error', () => {
    player.style.display = 'none';
    errorEl.style.display = 'block';
  });

  dlg.addEventListener('close', () => {
    player.pause();
    player.removeAttribute('src');
    player.load(); // release memory
    currentVideoId = null;
  });

  if (captureBtn) {
    captureBtn.addEventListener('click', async () => {
      if (!currentVideoId) return;
      const t = player.currentTime;
      if (!Number.isFinite(t)) {
        statusEl.textContent = 'Player belum siap.';
        return;
      }
      captureBtn.disabled = true;
      statusEl.textContent = `⏳ Capturing frame at ${t.toFixed(1)}s…`;
      try {
        const fd = new FormData();
        fd.append('at_second', t.toFixed(3));
        const r = await fetch('/videos/' + currentVideoId + '/regen-thumb', {
          method: 'POST',
          headers: { 'Accept': 'application/json' },
          body: fd,
        });
        if (!r.ok) throw new Error('HTTP ' + r.status);
        const j = await r.json();
        if (!j.ok) throw new Error(j.error || 'Failed');
        statusEl.textContent = `✓ Thumbnail updated (frame at ${t.toFixed(1)}s). Refresh library untuk lihat.`;
        // Bust cache on thumbnail images for this video in any open tab.
        document.querySelectorAll('img[src^="/videos/' + currentVideoId + '/thumb"]').forEach(img => {
          img.src = '/videos/' + currentVideoId + '/thumb?v=' + Date.now();
        });
      } catch (err) {
        statusEl.textContent = '✗ Gagal: ' + err.message;
      } finally {
        captureBtn.disabled = false;
      }
    });
  }
})();
</script>

