<%- include('partials/header', {
  title: 'Dashboard',
  activeNav: 'dashboard',
  pageTitle: 'Dashboard',
  pageSubtitle: 'Ringkasan aktivitas streaming kamu.',
}) %>

<!-- Main 4 cards (real-time) -->
<div class="stat-grid stat-grid-4">

  <div class="stat-card stat-card-plain">
    <div class="stat-icon stat-icon-purple">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12a7 7 0 0 1 14 0"/><path d="M2 12a10 10 0 0 1 20 0"/><circle cx="12" cy="12" r="2"/>
      </svg>
    </div>
    <div class="stat-body">
      <div class="stat-num" id="sys-streams"><%= runningCount %></div>
      <div class="stat-label">Active Streams</div>
    </div>
    <% if (runningCount > 0) { %><span class="stat-live">LIVE</span><% } %>
  </div>

  <div class="stat-card stat-card-plain">
    <div class="stat-icon stat-icon-blue">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h6v6H9z"/></svg>
    </div>
    <div class="stat-body">
      <div class="stat-num" id="sys-cpu"><%= system.cpuPercent %>%</div>
      <div class="stat-label">CPU Usage</div>
      <div class="stat-bar"><div class="stat-bar-fill stat-bar-blue" id="sys-cpu-bar" style="width:<%= system.cpuPercent %>%"></div></div>
    </div>
  </div>

  <div class="stat-card stat-card-plain">
    <div class="stat-icon stat-icon-green">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><rect x="6" y="6" width="12" height="12" rx="1"/></svg>
    </div>
    <div class="stat-body">
      <div class="stat-num" id="sys-mem"><%= (system.usedMem / (1024*1024*1024)).toFixed(1) %> GB<span class="stat-num-sub" id="sys-mem-total"> / <%= (system.totalMem / (1024*1024*1024)).toFixed(1) %> GB</span></div>
      <div class="stat-label">Memory</div>
      <div class="stat-bar"><div class="stat-bar-fill stat-bar-green" id="sys-mem-bar" style="width:<%= system.memPercent %>%"></div></div>
    </div>
  </div>

  <div class="stat-card stat-card-plain">
    <div class="stat-icon stat-icon-teal">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/></svg>
    </div>
    <div class="stat-body">
      <div class="stat-label">Internet Speed</div>
      <div class="stat-net-row"><span class="net-arrow">↑</span> Upload <span class="stat-net-val" id="sys-net-up">—</span></div>
      <div class="stat-net-row"><span class="net-arrow">↓</span> Download <span class="stat-net-val" id="sys-net-down">—</span></div>
    </div>
  </div>

</div>

<!-- Secondary info row -->
<div class="stat-grid stat-grid-5" style="margin-top:1rem">
  <a href="/videos" class="stat-card stat-card-sm">
    <div class="stat-body">
      <div class="stat-num-sm"><%= videoCount %></div>
      <div class="stat-label">Videos <span class="muted">(<%= readyCount %> ready)</span></div>
    </div>
  </a>
  <a href="/streams" class="stat-card stat-card-sm">
    <div class="stat-body">
      <div class="stat-num-sm"><%= streamCount %></div>
      <div class="stat-label">Streams</div>
    </div>
  </a>
  <a href="/schedules" class="stat-card stat-card-sm">
    <div class="stat-body">
      <div class="stat-num-sm"><%= pendingSchedules %></div>
      <div class="stat-label">Schedules</div>
    </div>
  </a>
  <div class="stat-card stat-card-sm">
    <div class="stat-body">
      <div class="stat-num-sm" id="sys-disk">
        <% if (system.disk && system.disk.total > 0) { %><%= system.disk.percent %>%<% } else { %>-<% } %>
      </div>
      <div class="stat-label">Disk <span class="muted" id="sys-disk-sub"><% if (system.disk && system.disk.total > 0) { %><%= (system.disk.used / (1024*1024*1024)).toFixed(1) %>/<%= (system.disk.total / (1024*1024*1024)).toFixed(1) %>GB<% } %></span></div>
    </div>
  </div>
  <div class="stat-card stat-card-sm">
    <div class="stat-body">
      <div class="stat-num-sm" id="sys-uptime"><%
        const d = Math.floor(system.uptime / 86400);
        const h = Math.floor((system.uptime % 86400) / 3600);
        const m = Math.floor((system.uptime % 3600) / 60);
      %><%= d > 0 ? d + 'd ' : '' %><%= h %>h <%= m %>m</div>
      <div class="stat-label">Uptime</div>
    </div>
  </div>
</div>

<script>
(function () {
  function fmtUptime(s) {
    const d = Math.floor(s / 86400), h = Math.floor((s % 86400) / 3600), m = Math.floor((s % 3600) / 60);
    return (d > 0 ? d + 'd ' : '') + h + 'h ' + m + 'm';
  }
  function fmtSpeed(bps) {
    if (bps == null || bps <= 0) return 'Idle';
    // Convert bytes/sec to megabits/sec (bps * 8 / 1_000_000)
    const mbps = (bps * 8) / 1000000;
    if (mbps < 1) return (mbps * 1000).toFixed(0) + ' Kbps';
    return mbps.toFixed(2) + ' Mbps';
  }
  function smoothUpdate(el, newText) {
    if (!el || el.textContent === newText) return;
    el.style.opacity = '0.5';
    el.textContent = newText;
    requestAnimationFrame(() => { el.style.opacity = '1'; });
  }
  function update(d) {
    smoothUpdate(document.getElementById('sys-cpu'), d.cpuPercent + '%');
    const cpuBar = document.getElementById('sys-cpu-bar');
    if (cpuBar) cpuBar.style.width = d.cpuPercent + '%';

    smoothUpdate(document.getElementById('sys-mem'), (d.usedMem / (1024*1024*1024)).toFixed(1) + ' GB');
    const memBar = document.getElementById('sys-mem-bar');
    if (memBar) memBar.style.width = d.memPercent + '%';

    smoothUpdate(document.getElementById('sys-uptime'), fmtUptime(d.uptime));

    if (d.disk && d.disk.total > 0) {
      smoothUpdate(document.getElementById('sys-disk'), d.disk.percent + '%');
      const diskSub = document.getElementById('sys-disk-sub');
      if (diskSub) diskSub.textContent = (d.disk.used / (1024*1024*1024)).toFixed(1) + '/' + (d.disk.total / (1024*1024*1024)).toFixed(1) + 'GB';
    }
    if (d.net && d.net.available) {
      smoothUpdate(document.getElementById('sys-net-up'), fmtSpeed(d.net.upload));
      smoothUpdate(document.getElementById('sys-net-down'), fmtSpeed(d.net.download));
    }
  }

  // Use SSE for real-time updates (no polling overhead).
  // Fallback to polling if SSE connection fails.
  if (window.EventSource) {
    const es = new EventSource('/api/events');
    let sseWorking = false;
    es.onmessage = (e) => {
      try { sseWorking = true; update(JSON.parse(e.data)); } catch (_) {}
    };
    es.onerror = () => {
      // If SSE never worked, fall back to polling.
      if (!sseWorking) {
        es.close();
        startPolling();
      }
    };
  } else {
    startPolling();
  }

  function startPolling() {
    async function poll() {
      try {
        const r = await fetch('/api/system', { cache: 'no-store' });
        if (r.ok) update(await r.json());
      } catch (_) {}
    }
    poll();
    setInterval(poll, 2000);
  }
})();

// Live duration timer for running streams.
(function () {
  function fmtDuration(sec) {
    const d = Math.floor(sec / 86400);
    const h = Math.floor((sec % 86400) / 3600);
    const m = Math.floor((sec % 3600) / 60);
    const s = Math.floor(sec % 60);
    if (d > 0) return d + 'd ' + h + 'h ' + m + 'm';
    if (h > 0) return h + 'h ' + m + 'm ' + s + 's';
    return m + 'm ' + s + 's';
  }
  function update() {
    document.querySelectorAll('.stream-timer[data-started-at]').forEach(el => {
      const raw = el.dataset.startedAt;
      if (!raw) return;
      const iso = raw.includes('T') ? raw : raw.replace(' ', 'T') + 'Z';
      const startMs = new Date(iso).getTime();
      if (Number.isNaN(startMs)) return;
      const elapsed = Math.max(0, Math.floor((Date.now() - startMs) / 1000));
      el.innerHTML = '🔴 <strong>' + fmtDuration(elapsed) + '</strong>';
    });
  }
  if (document.querySelectorAll('.stream-timer').length > 0) {
    update();
    setInterval(update, 1000);
  }
})();
</script>

<h2 class="section-heading" style="margin-top:1.5rem">Recent streams</h2>
<% if (recentStreams.length === 0) { %>
  <div class="card empty">
    <p class="muted">Belum ada stream. <a href="/streams">Buat sekarang</a>.</p>
  </div>
<% } else { %>
  <div class="table-wrap card card-flush">
    <table class="table videos-table">
      <thead><tr>
        <th class="col-w-thumb"></th>
        <th class="col-w-title">Stream</th>
        <th class="col-w-platform">Platform</th>
        <th class="col-w-status">Status</th>
        <th class="col-w-actions">Actions</th>
      </tr></thead>
      <tbody>
        <% recentStreams.forEach(s => { %>
          <tr>
            <td class="col-thumb">
              <% if (s.video_thumb) { %>
                <img src="/uploads/thumbs/<%= s.video_thumb %>" alt="" class="video-thumb" loading="lazy" style="width:140px;height:79px">
              <% } else { %>
                <div class="video-thumb video-thumb-empty" style="width:140px;height:79px;cursor:default">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="14" height="14" rx="2"/><path d="M22 7l-6 5 6 5V7z"/></svg>
                </div>
              <% } %>
            </td>
            <td class="video-title-cell">
              <div class="video-title"><%= s.name %></div>
              <div class="video-meta small muted"><%= s.video_title || '(deleted)' %><%= s.playlist_name ? ' · Playlist: ' + s.playlist_name : '' %></div>
            </td>
            <td><%= s.platform.charAt(0).toUpperCase() + s.platform.slice(1) %></td>
            <td>
              <span class="badge badge-<%= s.status %>"><%= s.status %></span>
              <% if (s.status === 'running' && s.started_at) { %>
                <div class="stream-timer small" data-started-at="<%= s.started_at %>"></div>
              <% } %>
            </td>
            <td class="actions">
              <% if (s.status === 'running') { %>
                <form method="POST" action="/streams/<%= s.id %>/stop" class="inline">
                  <button class="btn-icon btn-icon-warn" type="submit" title="Stop">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="1"/></svg>
                  </button>
                </form>
              <% } else { %>
                <form method="POST" action="/streams/<%= s.id %>/start" class="inline">
                  <button class="btn-icon btn-icon-primary" type="submit" title="Start">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                  </button>
                </form>
              <% } %>
              <a href="/streams/<%= s.playlist_id ? 'playlist' : 'single' %>" class="btn-icon" title="Go to streams">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% if (typeof historyCount !== 'undefined' && historyCount > 0) { %>
    <p class="muted small" style="margin-top:0.5rem"><a href="/history">View full history (<%= historyCount %> entries)</a></p>
  <% } %>
<% } %>
<%- include('partials/footer') %>
